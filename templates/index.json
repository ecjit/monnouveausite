        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .ann-bar {\n    --pink:  #E8547A;\n    --dark:  #1C1C2E;\n    --gold:  #e8c97e;\n    --white: #ffffff;\n    background: var(--dark);\n    overflow: hidden;\n    white-space: nowrap;\n    padding: 11px 0;\n    font-family: 'Inter', -apple-system, sans-serif;\n    width: 100%;\n    position: relative;\n    z-index: 100;\n  }\n\n  /* ── TRACK DÉFILANT ── */\n  .ann-track {\n    display: inline-flex;\n    align-items: center;\n    animation: ann-scroll 35s linear infinite;\n  }\n\n  .ann-track:hover {\n    animation-play-state: paused;\n  }\n\n  /* ── ITEM ── */\n  .ann-item {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 0 32px;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--white);\n    white-space: nowrap;\n  }\n\n  /* Point séparateur doré */\n  .ann-dot {\n    width: 5px;\n    height: 5px;\n    background: var(--gold);\n    border-radius: 50%;\n    flex-shrink: 0;\n    display: inline-block;\n  }\n\n  /* Icône optionnelle avant le texte */\n  .ann-icon {\n    font-size: 13px;\n    line-height: 1;\n    flex-shrink: 0;\n  }\n\n  /* Texte en rose pour mettre en valeur */\n  .ann-item .highlight {\n    color: var(--gold);\n  }\n\n  @keyframes ann-scroll {\n    from { transform: translateX(0); }\n    to   { transform: translateX(-50%); }\n  }\n</style>\n\n<div class=\"ann-bar\" role=\"marquee\" aria-label=\"Annonces\">\n  <div class=\"ann-track\">\n\n    {%- comment -%}\n      ══════════════════════════════════════════\n      PERSONNALISATION\n      Modifiez les textes ci-dessous librement.\n      Dupliquez un bloc <span class=\"ann-item\">\n      pour ajouter un message.\n      Les blocs sont dupliqués (x2) pour la\n      boucle infinie.\n      ══════════════════════════════════════════\n    {%- endcomment -%}\n\n    {%- for i in (1..2) -%}\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">↩️</span>\n        Satisfaite ou remboursée — <span class=\"highlight\">&nbsp;90 jours</span>\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">⭐</span>\n        <span class=\"highlight\">+1 500 clientes</span>&nbsp; satisfaites · Note 4.8/5\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🔒</span>\n        Paiement <span class=\"highlight\">&nbsp;100% sécurisé</span> &nbsp;· Données protégées\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🚚</span>\n        Livraison <span class=\"highlight\">&nbsp;rapide & sécurisée</span> &nbsp;· Suivi inclus\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">⏳</span>\n        Stock limité — <span class=\"highlight\">&nbsp;Plus que 5 unités</span> &nbsp;disponibles !\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🔥</span>\n        Offre expire dans <span class=\"highlight\">&nbsp;24h</span> &nbsp;— Ne ratez pas cette opportunité !\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🎁</span>\n        Sérum contour des yeux <span class=\"highlight\">&nbsp;offert</span> &nbsp;avec chaque commande\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">📖</span>\n        Guide beauté anti-âge <span class=\"highlight\">&nbsp;offert</span> &nbsp;à chaque achat\n        <span class=\"ann-dot\"></span>\n      </span>\n\n    {%- endfor -%}\n\n  </div>\n</div>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_9kWwhi": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<section class=\"sk-led-section\">\n  <div class=\"sk-led-inner\">\n\n    <h2 class=\"sk-led-title\">OBTENEZ DES SOINS À PLUSIEURS CENTAINES D'EUROS<br><span>AVEC UN SEUL APPAREIL</span></h2>\n\n    <div class=\"sk-led-grid\">\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(220,50,50,0.15) 0%, transparent 70%); border-color: #DC3232;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#DC3232\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(220,50,50,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#DC3232;\">LUMIÈRE ROUGE <span>(630nm)</span></p>\n        <p class=\"sk-led-desc\">Stimule la production de collagène, prévient les ridules, les rides et le relâchement cutané.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(50,100,220,0.15) 0%, transparent 70%); border-color: #3264DC;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#3264DC\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(50,100,220,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#3264DC;\">LUMIÈRE BLEUE <span>(415nm)</span></p>\n        <p class=\"sk-led-desc\">Élimine les bactéries responsables de l'acné, réduit les imperfections et les boutons.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(50,180,80,0.15) 0%, transparent 70%); border-color: #32B450;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#32B450\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(50,180,80,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#32B450;\">LUMIÈRE VERTE <span>(525nm)</span></p>\n        <p class=\"sk-led-desc\">Unifie le teint et améliore la texture globale de la peau.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(0,190,200,0.15) 0%, transparent 70%); border-color: #00BEC8;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#00BEC8\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(0,190,200,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#00BEC8;\">LUMIÈRE CYAN <span>(490nm)</span></p>\n        <p class=\"sk-led-desc\">Apaise les peaux sensibles, réduit les rougeurs, l'inflammation et les irritations.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(200,200,200,0.15) 0%, transparent 70%); border-color: #AAAAAA;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#AAAAAA\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(200,200,200,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#888888;\">LUMIÈRE BLANCHE <span>(Mix)</span></p>\n        <p class=\"sk-led-desc\">Favorise le renouvellement cellulaire et cible les ridules et les rides fines.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(160,50,220,0.15) 0%, transparent 70%); border-color: #A032DC;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#A032DC\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(160,50,220,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#A032DC;\">LUMIÈRE VIOLETTE <span>(380nm)</span></p>\n        <p class=\"sk-led-desc\">Combine les bienfaits du rouge et du bleu pour un effet anti-âge et purifiant simultané.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(220,180,50,0.15) 0%, transparent 70%); border-color: #DCB432;\">\n          <svg viewBox=\"0 0 60 40\" fill=\"none\"><ellipse cx=\"30\" cy=\"20\" rx=\"28\" ry=\"14\" stroke=\"#DCB432\" stroke-width=\"2.5\"/><ellipse cx=\"30\" cy=\"20\" rx=\"18\" ry=\"9\" fill=\"rgba(220,180,50,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#DCB432;\">LUMIÈRE JAUNE <span>(590nm)</span></p>\n        <p class=\"sk-led-desc\">Stimule le drainage lymphatique et améliore la circulation sanguine.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(180,180,180,0.1) 0%, transparent 70%); border-color: #CCCCCC;\">\n          <svg viewBox=\"0 0 60 60\" fill=\"none\"><circle cx=\"30\" cy=\"30\" r=\"22\" stroke=\"#CCCCCC\" stroke-width=\"2\"/><path d=\"M20 30 Q30 18 40 30 Q30 42 20 30Z\" fill=\"rgba(180,180,180,0.3)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#888;\">MODE EMS</p>\n        <p class=\"sk-led-desc\">Tonifie les muscles du visage, améliore le galbe et réduit les ridules.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(220,100,50,0.1) 0%, transparent 70%); border-color: #DC6432;\">\n          <svg viewBox=\"0 0 60 60\" fill=\"none\"><path d=\"M20 45 Q25 20 30 15 Q35 20 40 45\" stroke=\"#DC6432\" stroke-width=\"2.5\" fill=\"none\"/><path d=\"M24 45 Q27 28 30 23 Q33 28 36 45\" stroke=\"#DC6432\" stroke-width=\"1.5\" fill=\"rgba(220,100,50,0.15)\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#DC6432;\">MODE CHALEUR</p>\n        <p class=\"sk-led-desc\">Ouvre les pores pour améliorer l'absorption des soins et stimule la production de collagène.</p>\n      </div>\n\n      <div class=\"sk-led-card\">\n        <div class=\"sk-led-icon\" style=\"background: radial-gradient(circle, rgba(100,180,220,0.1) 0%, transparent 70%); border-color: #64B4DC;\">\n          <svg viewBox=\"0 0 60 60\" fill=\"none\"><circle cx=\"30\" cy=\"30\" r=\"20\" stroke=\"#64B4DC\" stroke-width=\"2\"/><path d=\"M22 30 L28 36 L38 24\" stroke=\"#64B4DC\" stroke-width=\"2.5\" stroke-linecap=\"round\"/></svg>\n        </div>\n        <p class=\"sk-led-name\" style=\"color:#64B4DC;\">MODE CLEAN</p>\n        <p class=\"sk-led-desc\">Prévient l'acné en éliminant les cellules mortes, l'excès de sébum et les impuretés des pores.</p>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<style>\n.sk-led-section { background: #fff; padding: 60px 20px; font-family: 'Poppins', sans-serif; }\n.sk-led-inner { max-width: 1100px; margin: 0 auto; }\n.sk-led-title { text-align: center; font-size: 22px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #1a1a1a; margin-bottom: 50px; line-height: 1.4; }\n.sk-led-title span { color: #E8526A; }\n.sk-led-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; }\n.sk-led-card { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 20px 12px; border-radius: 16px; background: #fafafa; transition: transform 0.2s ease, box-shadow 0.2s ease; }\n.sk-led-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }\n.sk-led-icon { width: 72px; height: 72px; border-radius: 50%; border: 2px solid; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; padding: 12px; }\n.sk-led-icon svg { width: 100%; height: 100%; }\n.sk-led-name { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }\n.sk-led-name span { display: block; font-weight: 400; font-size: 10px; opacity: 0.8; }\n.sk-led-desc { font-size: 11px; color: #666; line-height: 1.5; }\n@media (max-width: 900px) { .sk-led-grid { grid-template-columns: repeat(3, 1fr); } }\n@media (max-width: 600px) { .sk-led-grid { grid-template-columns: repeat(2, 1fr); } .sk-led-title { font-size: 16px; } }\n</style>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
