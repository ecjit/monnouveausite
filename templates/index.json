        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .skrat-wrap {\n    --pink:       #E8547A;\n    --pink-light: #fce8ef;\n    --pink-mid:   #f4a8bc;\n    --dark:       #1C1C2E;\n    --white:      #ffffff;\n    --grey:       #f7f4f8;\n    --text-soft:  rgba(28,28,46,0.5);\n    --border:     rgba(232,84,122,0.15);\n    --gold:       #f5c518;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    background: var(--grey);\n    padding: 48px 24px 56px;\n  }\n\n  /* ─── HEADER ─── */\n  .skrat-header {\n    text-align: center;\n    margin-bottom: 36px;\n  }\n  .skrat-tag {\n    display: inline-block;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--pink);\n    border: 1.5px solid var(--pink);\n    border-radius: 100px;\n    padding: 5px 16px;\n    margin-bottom: 16px;\n  }\n  .skrat-header h2 {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: clamp(1.8rem, 3.5vw, 2.6rem);\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.2;\n    margin: 0;\n  }\n  .skrat-header h2 em {\n    font-style: italic;\n    color: var(--pink);\n  }\n\n  /* ─── GRILLE ─── */\n  .skrat-grid {\n    display: grid;\n    grid-template-columns: 220px 1fr 200px;\n    gap: 20px;\n    max-width: 900px;\n    margin: 0 auto;\n    align-items: stretch;\n  }\n\n  @media (max-width: 768px) {\n    .skrat-grid {\n      grid-template-columns: 1fr;\n    }\n  }\n\n  /* ─── CARD COMMUNE ─── */\n  .skrat-card {\n    background: var(--white);\n    border-radius: 20px;\n    border: 1.5px solid var(--border);\n    box-shadow: 0 4px 20px rgba(28,28,46,0.06);\n    padding: 28px 24px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n  }\n\n  /* ─── BLOC NOTE GLOBALE ─── */\n  .skrat-score {\n    font-family: 'Playfair Display', serif;\n    font-size: 3rem;\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1;\n    margin-bottom: 8px;\n  }\n\n  .skrat-stars-big {\n    color: var(--gold);\n    font-size: 22px;\n    letter-spacing: 3px;\n    margin-bottom: 10px;\n  }\n\n  .skrat-count {\n    font-size: 12px;\n    color: var(--text-soft);\n    font-weight: 500;\n    display: flex;\n    align-items: center;\n    gap: 5px;\n  }\n\n  .skrat-verified {\n    width: 14px; height: 14px;\n    background: #2ecc71;\n    border-radius: 50%;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .skrat-verified svg {\n    width: 8px; height: 8px;\n    stroke: #fff; stroke-width: 2.5;\n    fill: none; stroke-linecap: round; stroke-linejoin: round;\n  }\n\n  /* ─── BLOC BARRES ─── */\n  .skrat-bars {\n    align-items: stretch;\n  }\n\n  .skrat-bar-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 10px;\n    cursor: pointer;\n    transition: opacity 0.2s;\n  }\n\n  .skrat-bar-row:last-child { margin-bottom: 0; }\n  .skrat-bar-row:hover { opacity: 0.7; }\n\n  .skrat-bar-label {\n    font-size: 12px;\n    font-weight: 700;\n    color: var(--dark);\n    width: 28px;\n    white-space: nowrap;\n    flex-shrink: 0;\n  }\n\n  .skrat-bar-track {\n    flex: 1;\n    height: 7px;\n    background: var(--border);\n    border-radius: 100px;\n    overflow: hidden;\n  }\n\n  .skrat-bar-fill {\n    height: 100%;\n    background: linear-gradient(90deg, var(--pink-mid), var(--pink));\n    border-radius: 100px;\n    transition: width 0.8s ease;\n  }\n\n  .skrat-bar-count {\n    font-size: 12px;\n    color: var(--text-soft);\n    font-weight: 500;\n    width: 36px;\n    text-align: right;\n    flex-shrink: 0;\n  }\n\n  /* ─── BOUTON CTA ─── */\n  .skrat-cta-wrap {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .skrat-cta {\n    width: 100%;\n    background: var(--pink);\n    color: #fff;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    padding: 16px 20px;\n    border: none;\n    border-radius: 14px;\n    cursor: pointer;\n    text-align: center;\n    transition: background 0.25s, transform 0.2s, box-shadow 0.25s;\n    box-shadow: 0 8px 24px rgba(232,84,122,0.35);\n    line-height: 1.4;\n  }\n\n  .skrat-cta:hover {\n    background: var(--dark);\n    transform: translateY(-2px);\n    box-shadow: 0 14px 32px rgba(28,28,46,0.2);\n  }\n</style>\n\n<div class=\"skrat-wrap\">\n\n  <!-- HEADER -->\n  <div class=\"skrat-header\">\n    <div class=\"skrat-tag\">Avis clients</div>\n    <h2>Ce que disent <em>nos clientes</em></h2>\n  </div>\n\n  <!-- GRILLE -->\n  <div class=\"skrat-grid\">\n\n    <!-- Note globale -->\n    <div class=\"skrat-card\">\n      <div class=\"skrat-score\">4,8</div>\n      <div class=\"skrat-stars-big\">★★★★★</div>\n      <div class=\"skrat-count\">\n        <span class=\"skrat-verified\">\n          <svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg>\n        </span>\n        Basé sur 1 300 avis vérifiés\n      </div>\n    </div>\n\n    <!-- Barres de progression -->\n    <div class=\"skrat-card skrat-bars\">\n      <div class=\"skrat-bar-row\" onclick=\"filterLooxReviews(5)\">\n        <span class=\"skrat-bar-label\">5 ★</span>\n        <div class=\"skrat-bar-track\"><div class=\"skrat-bar-fill\" style=\"width:85%\"></div></div>\n        <span class=\"skrat-bar-count\">1 697</span>\n      </div>\n      <div class=\"skrat-bar-row\" onclick=\"filterLooxReviews(4)\">\n        <span class=\"skrat-bar-label\">4 ★</span>\n        <div class=\"skrat-bar-track\"><div class=\"skrat-bar-fill\" style=\"width:9%\"></div></div>\n        <span class=\"skrat-bar-count\">177</span>\n      </div>\n      <div class=\"skrat-bar-row\" onclick=\"filterLooxReviews(3)\">\n        <span class=\"skrat-bar-label\">3 ★</span>\n        <div class=\"skrat-bar-track\"><div class=\"skrat-bar-fill\" style=\"width:3%\"></div></div>\n        <span class=\"skrat-bar-count\">59</span>\n      </div>\n      <div class=\"skrat-bar-row\" onclick=\"filterLooxReviews(2)\">\n        <span class=\"skrat-bar-label\">2 ★</span>\n        <div class=\"skrat-bar-track\"><div class=\"skrat-bar-fill\" style=\"width:1%\"></div></div>\n        <span class=\"skrat-bar-count\">22</span>\n      </div>\n      <div class=\"skrat-bar-row\" onclick=\"filterLooxReviews(1)\">\n        <span class=\"skrat-bar-label\">1 ★</span>\n        <div class=\"skrat-bar-track\"><div class=\"skrat-bar-fill\" style=\"width:1%\"></div></div>\n        <span class=\"skrat-bar-count\">17</span>\n      </div>\n    </div>\n\n    <!-- Bouton -->\n    <div class=\"skrat-card skrat-cta-wrap\">\n      <button class=\"skrat-cta\" onclick=\"openLooxReviewForm()\">\n        ✍️ Écrire<br>un avis\n      </button>\n    </div>\n\n  </div>\n</div>\n\n<script>\nfunction filterLooxReviews(stars) {\n  var looxReviews = document.querySelector('[id*=\"loox\"]') || document.querySelector('.loox-reviews-default');\n  if (looxReviews) {\n    looxReviews.scrollIntoView({ behavior: 'smooth', block: 'start' });\n  }\n}\n\nfunction openLooxReviewForm() {\n  var allButtons = document.querySelectorAll('button, a, div[role=\"button\"]');\n  var looxButton = null;\n  for (var i = 0; i < allButtons.length; i++) {\n    var btn = allButtons[i];\n    var text = btn.textContent.toLowerCase().trim();\n    var hasLooxStyle = (btn.style.background && btn.style.background.includes('e8e8e8')) ||\n                       (btn.style.border && btn.style.border.includes('e8e8e8')) ||\n                       (btn.className && btn.className.includes('loox'));\n    if ((text === 'écrire un avis' || text === 'write a review') && hasLooxStyle) {\n      looxButton = btn;\n      break;\n    }\n  }\n  if (looxButton) {\n    looxButton.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    setTimeout(function() { looxButton.click(); }, 800);\n  } else {\n    var looxWidget = document.querySelector('[id*=\"loox\"]');\n    if (looxWidget) {\n      var widgetButtons = looxWidget.querySelectorAll('button, a, div[onclick]');\n      for (var j = 0; j < widgetButtons.length; j++) {\n        var wb = widgetButtons[j];\n        if (wb.textContent.toLowerCase().includes('écrire') || wb.textContent.toLowerCase().includes('write')) {\n          wb.scrollIntoView({ behavior: 'smooth', block: 'center' });\n          setTimeout(function() { wb.click(); }, 800);\n          return;\n        }\n      }\n      looxWidget.scrollIntoView({ behavior: 'smooth', block: 'end' });\n    }\n  }\n}\n</script>",
