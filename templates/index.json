        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .how-section {\n    background-color: #f7f4f8;\n    padding: 64px 20px 72px;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n  }\n\n  .how-inner {\n    max-width: 1100px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 64px;\n    align-items: center;\n  }\n\n  /* ─── IMAGE ─── */\n  .how-gif img {\n    width: 100%;\n    height: auto;\n    border-radius: 22px;\n    display: block;\n    box-shadow: 0 16px 56px rgba(232,84,122,0.13), 0 4px 18px rgba(28,28,46,0.07);\n  }\n\n  /* ─── TAG ─── */\n  .how-tag {\n    display: inline-block;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: #E8547A;\n    border: 1.5px solid #E8547A;\n    border-radius: 100px;\n    padding: 5px 16px;\n    margin-bottom: 16px;\n  }\n\n  /* ─── TITRE ─── */\n  .how-title {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-weight: 700;\n    font-size: clamp(1.8rem, 3vw, 2.6rem);\n    color: #1C1C2E;\n    letter-spacing: 0.01em;\n    line-height: 1.2;\n    margin: 0 0 6px;\n    text-transform: none;\n  }\n\n  .how-title span {\n    font-style: italic;\n    color: #E8547A;\n    font-weight: 400;\n  }\n\n  /* ─── SÉPARATEUR ─── */\n  .how-divider {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 36px;\n    max-width: 200px;\n  }\n\n  .how-line {\n    flex: 1;\n    height: 1.5px;\n    background: rgba(232,84,122,0.25);\n    border-radius: 2px;\n  }\n\n  .how-diamond {\n    width: 6px;\n    height: 6px;\n    background: #E8547A;\n    transform: rotate(45deg);\n    flex-shrink: 0;\n    border-radius: 1px;\n  }\n\n  /* ─── ÉTAPES ─── */\n  .how-steps {\n    display: flex;\n    flex-direction: column;\n    gap: 24px;\n  }\n\n  .how-step {\n    display: flex;\n    gap: 20px;\n    align-items: flex-start;\n    padding: 18px 20px;\n    background: #ffffff;\n    border-radius: 16px;\n    border: 1.5px solid rgba(232,84,122,0.1);\n    box-shadow: 0 2px 12px rgba(28,28,46,0.05);\n    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;\n  }\n\n  .how-step:hover {\n    border-color: rgba(232,84,122,0.3);\n    box-shadow: 0 8px 32px rgba(232,84,122,0.1);\n    transform: translateX(4px);\n  }\n\n  /* Numéro */\n  .step-num {\n    min-width: 44px;\n    height: 44px;\n    border-radius: 50%;\n    background: #E8547A;\n    color: #fff;\n    font-weight: 800;\n    font-size: 16px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    box-shadow: 0 4px 14px rgba(232,84,122,0.4);\n    font-family: 'Playfair Display', serif;\n  }\n\n  /* Texte étape */\n  .step-title {\n    font-family: 'Inter', sans-serif;\n    font-weight: 700;\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    color: #1C1C2E;\n    margin-bottom: 3px;\n  }\n\n  .step-sub {\n    font-family: 'Playfair Display', serif;\n    font-size: 12.5px;\n    font-style: italic;\n    color: #E8547A;\n    font-weight: 400;\n    margin-bottom: 6px;\n  }\n\n  .step-desc {\n    font-size: 12.5px;\n    color: rgba(28,28,46,0.55);\n    line-height: 1.75;\n  }\n\n  /* ─── RESPONSIVE ─── */\n  @media (max-width: 768px) {\n    .how-inner {\n      grid-template-columns: 1fr;\n      gap: 40px;\n    }\n  }\n</style>\n\n<div class=\"how-section\">\n  <div class=\"how-inner\">\n\n    <!-- IMAGE / GIF -->\n    <div class=\"how-gif\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/Timeline1test-ezgif.com-resize.webp\" alt=\"SkinYliss en action\">\n    </div>\n\n    <!-- CONTENU -->\n    <div class=\"how-content\">\n      <div class=\"how-tag\">Protocole d'utilisation</div>\n      <h2 class=\"how-title\">Comment <span>l'utiliser</span> ?</h2>\n      <div class=\"how-divider\">\n        <div class=\"how-line\"></div>\n        <div class=\"how-diamond\"></div>\n        <div class=\"how-line\"></div>\n      </div>\n\n      <div class=\"how-steps\">\n\n        <div class=\"how-step\">\n          <div class=\"step-num\">1</div>\n          <div class=\"step-content\">\n            <p class=\"step-title\">Allumez l'appareil</p>\n            <p class=\"step-sub\">Lancez votre rituel beauté</p>\n            <p class=\"step-desc\">Maintenez le bouton d'alimentation 3 secondes. Appliquez votre sérum ou hydratant au préalable.</p>\n          </div>\n        </div>\n\n        <div class=\"how-step\">\n          <div class=\"step-num\">2</div>\n          <div class=\"step-content\">\n            <p class=\"step-title\">Choisissez une LED & un mode</p>\n            <p class=\"step-sub\">Personnalisez votre soin anti-âge</p>\n            <p class=\"step-desc\">7 réglages LED disponibles. Basculez entre les modes EMS, Clean et Heat selon vos besoins.</p>\n          </div>\n        </div>\n\n        <div class=\"how-step\">\n          <div class=\"step-num\">3</div>\n          <div class=\"step-content\">\n            <p class=\"step-title\">Commencez le massage</p>\n            <p class=\"step-sub\">Révélez votre plus belle peau</p>\n            <p class=\"step-desc\">Massez votre visage comme avec un gua sha. Profitez de votre rituel bien-être quotidien.</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n  </div>\n</div>",
        "background": "#ffffff",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_tcD4Wa": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  /* ─── TICKER ─── */\n  .skfaq-ticker-wrap {\n    background: #1C1C2E;\n    overflow: hidden;\n    white-space: nowrap;\n    padding: 10px 0;\n    font-family: 'Inter', sans-serif;\n  }\n  .skfaq-ticker-track {\n    display: inline-flex;\n    animation: skfaq-ticker 32s linear infinite;\n  }\n  .skfaq-ticker-track:hover { animation-play-state: paused; }\n  .skfaq-ticker-item {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 0 30px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.13em;\n    text-transform: uppercase;\n    color: #fff;\n  }\n  .skfaq-ticker-dot {\n    width: 5px; height: 5px;\n    background: #E8547A;\n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n  @keyframes skfaq-ticker {\n    from { transform: translateX(0); }\n    to   { transform: translateX(-50%); }\n  }\n\n  /* ─── SECTION ─── */\n  .skfaq-section {\n    --pink:       #E8547A;\n    --pink-light: #fce8ef;\n    --pink-mid:   #f4a8bc;\n    --dark:       #1C1C2E;\n    --white:      #ffffff;\n    --grey:       #f7f4f8;\n    --text-soft:  rgba(28,28,46,0.5);\n    --border:     rgba(232,84,122,0.15);\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    background: var(--grey);\n    padding: 64px 24px 80px;\n  }\n\n  /* ─── HEADER ─── */\n  .skfaq-header {\n    text-align: center;\n    margin-bottom: 52px;\n  }\n  .skfaq-tag {\n    display: inline-block;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--pink);\n    border: 1.5px solid var(--pink);\n    border-radius: 100px;\n    padding: 5px 16px;\n    margin-bottom: 16px;\n  }\n  .skfaq-header h2 {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: clamp(1.9rem, 4vw, 3rem);\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.2;\n    margin: 0 0 12px;\n  }\n  .skfaq-header h2 em {\n    font-style: italic;\n    color: var(--pink);\n  }\n  .skfaq-header p {\n    font-size: 14px;\n    color: var(--text-soft);\n    max-width: 480px;\n    margin: 0 auto;\n    line-height: 1.7;\n  }\n\n  /* ─── ACCORDION ─── */\n  .skfaq-layout {\n    max-width: 780px;\n    margin: 0 auto;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n\n  .skfaq-item {\n    background: var(--white);\n    border-radius: 16px;\n    overflow: hidden;\n    box-shadow: 0 2px 12px rgba(28,28,46,0.05);\n    border: 1.5px solid transparent;\n    transition: border-color 0.3s, box-shadow 0.3s;\n  }\n  .skfaq-item.open {\n    border-color: var(--border);\n    box-shadow: 0 8px 32px rgba(232,84,122,0.1);\n  }\n\n  .skfaq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 20px 22px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    cursor: pointer;\n    text-align: left;\n  }\n\n  .skfaq-q-left {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n\n  .skfaq-q-icon {\n    width: 32px; height: 32px;\n    background: var(--pink-light);\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n    font-size: 14px;\n    transition: background 0.3s;\n  }\n  .skfaq-item.open .skfaq-q-icon { background: var(--pink); }\n  .skfaq-item.open .skfaq-q-icon span { filter: brightness(10); }\n\n  .skfaq-q-text {\n    font-size: 14px;\n    font-weight: 600;\n    color: var(--dark);\n    line-height: 1.4;\n    transition: color 0.2s;\n  }\n  .skfaq-item.open .skfaq-q-text { color: var(--pink); }\n\n  /* Chevron */\n  .skfaq-chevron {\n    width: 28px; height: 28px;\n    border-radius: 50%;\n    border: 1.5px solid var(--border);\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n    transition: transform 0.35s ease, background 0.3s, border-color 0.3s;\n    background: var(--white);\n  }\n  .skfaq-item.open .skfaq-chevron {\n    transform: rotate(180deg);\n    background: var(--pink);\n    border-color: var(--pink);\n  }\n  .skfaq-chevron svg {\n    width: 12px; height: 12px;\n    stroke: var(--dark); stroke-width: 2.5;\n    fill: none; stroke-linecap: round; stroke-linejoin: round;\n    transition: stroke 0.3s;\n  }\n  .skfaq-item.open .skfaq-chevron svg { stroke: #fff; }\n\n  /* ─── RÉPONSE ─── */\n  .skfaq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  .skfaq-item.open .skfaq-answer { max-height: 500px; }\n\n  .skfaq-answer-inner {\n    padding: 16px 22px 22px 68px;\n    font-size: 13.5px;\n    color: var(--text-soft);\n    line-height: 1.8;\n    border-top: 1px solid var(--border);\n  }\n  .skfaq-answer-inner strong { color: var(--dark); font-weight: 600; }\n\n  /* ─── FOOTER CTA ─── */\n  .skfaq-footer {\n    text-align: center;\n    margin-top: 48px;\n    padding: 36px 32px;\n    background: var(--white);\n    border-radius: 20px;\n    max-width: 780px;\n    margin-left: auto;\n    margin-right: auto;\n    box-shadow: 0 4px 24px rgba(28,28,46,0.06);\n    border: 1.5px solid var(--border);\n  }\n  .skfaq-footer p {\n    font-family: 'Playfair Display', serif;\n    font-size: 1.2rem;\n    font-weight: 700;\n    color: var(--dark);\n    margin: 0 0 6px;\n  }\n  .skfaq-footer small {\n    font-size: 13px;\n    color: var(--text-soft);\n    display: block;\n    margin-bottom: 20px;\n  }\n  .skfaq-cta {\n    display: inline-block;\n    background: var(--pink);\n    color: #fff;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    padding: 14px 32px;\n    border-radius: 100px;\n    text-decoration: none;\n    transition: background 0.25s, transform 0.2s, box-shadow 0.25s;\n    box-shadow: 0 8px 24px rgba(232,84,122,0.35);\n  }\n  .skfaq-cta:hover {\n    background: #1C1C2E;\n    transform: translateY(-2px);\n    box-shadow: 0 14px 32px rgba(28,28,46,0.2);\n  }\n</style>\n\n<!-- TICKER -->\n<div class=\"skfaq-ticker-wrap\" aria-hidden=\"true\">\n  <div class=\"skfaq-ticker-track\">\n    {% assign skfaq_phrases = \"Raffermit les Bajoues & le Cou,Effet Lifting Immédiat,Réduit le Double Menton,Lisse les Rides & Ridules,Drainage Lymphatique Naturel,Satisfait ou Remboursé 90 Jours,Sans Injection ni Chirurgie\" | split: \",\" %}\n    {% for i in (1..2) %}\n      {% for phrase in skfaq_phrases %}\n        <span class=\"skfaq-ticker-item\">\n          <span class=\"skfaq-ticker-dot\"></span>{{ phrase }}\n        </span>\n      {% endfor %}\n    {% endfor %}\n  </div>\n</div>\n\n<!-- SECTION FAQ -->\n<section class=\"skfaq-section\">\n\n  <div class=\"skfaq-header\">\n    <div class=\"skfaq-tag\">Questions fréquentes</div>\n    <h2>Tout savoir sur <em>Skinyliss</em></h2>\n    <p>Vos questions sur le Sculpteur Facial Skinyliss, répondues avec précision.</p>\n  </div>\n\n  <div class=\"skfaq-layout\" id=\"skfaqList\">\n\n    <!-- Q1 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>⏱</span></div>\n          <span class=\"skfaq-q-text\">En combien de temps vais-je voir des résultats visibles ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          La majorité de nos clientes constatent une <strong>première amélioration dès 7 à 10 jours</strong> — la peau paraît plus tonifiée et le visage moins fatigué. Les résultats les plus marquants apparaissent entre <strong>3 et 6 semaines</strong> d'utilisation régulière : raffermissement des bajoues, réduction du double menton et lissage visible des rides.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q2 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>💆‍♀️</span></div>\n          <span class=\"skfaq-q-text\">Le Sculpteur Facial Skinyliss est-il douloureux à utiliser ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Non, l'appareil est <strong>totalement indolore</strong>. Vous ressentirez de légères vibrations et une douce chaleur agréable sur la peau. La plupart des utilisatrices décrivent la sensation comme un <strong>massage relaxant</strong>. Vous pouvez régler l'intensité selon votre confort grâce aux différents modes disponibles.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q3 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>🔁</span></div>\n          <span class=\"skfaq-q-text\">À quelle fréquence dois-je utiliser le Sculpteur Facial ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Nous recommandons une utilisation <strong>quotidienne de 10 minutes</strong> pour des résultats optimaux — idéalement le matin ou le soir après votre routine nettoyante. Une fois les résultats atteints, <strong>3 à 4 séances par semaine</strong> suffisent pour maintenir l'effet lifting et sculptant.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q4 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>🧴</span></div>\n          <span class=\"skfaq-q-text\">Dois-je utiliser un sérum ou une crème avec l'appareil ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Oui, nous recommandons fortement d'appliquer un <strong>sérum ou une crème hydratante</strong> avant chaque séance. Cela améliore le glissement de l'appareil sur la peau et amplifie les effets EMS et LED. Le Skinyliss permet à vos soins de pénétrer <strong>jusqu'à 3x plus en profondeur</strong>, maximisant ainsi leur efficacité.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q5 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>🌿</span></div>\n          <span class=\"skfaq-q-text\">Le Sculpteur Facial convient-il à tous les types de peau ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Oui, le Skinyliss est conçu pour <strong>tous les types de peau</strong> — sèche, mixte, grasse ou sensible. La technologie LED est non-invasive et sans UV. Si vous avez une condition dermatologique particulière (eczéma, rosacée active, peau lésée), nous vous recommandons de <strong>consulter votre dermatologue</strong> avant utilisation.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q6 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>⚡</span></div>\n          <span class=\"skfaq-q-text\">Quelles sont les technologies utilisées dans l'appareil ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Le Sculpteur Facial Skinyliss combine <strong>3 technologies avancées</strong> : la <strong>LED 7 couleurs</strong> pour stimuler le collagène et améliorer le teint, l'<strong>EMS (stimulation musculaire électrique)</strong> pour raffermir et tonifier les muscles du visage, et la <strong>chaleur infrarouge douce</strong> pour activer la circulation et favoriser l'absorption des soins.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q7 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>🏆</span></div>\n          <span class=\"skfaq-q-text\">Quelle est la différence entre Skinyliss et les autres appareils du marché ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Le Skinyliss se distingue par sa <strong>combinaison unique de 3 technologies</strong> dans un seul appareil ergonomique. Contrairement à la majorité des appareils qui ne proposent qu'une seule technologie, le Skinyliss agit simultanément sur la <strong>fermeté</strong>, l'<strong>éclat</strong> et le <strong>remodelage du contour facial</strong>. Sa forme en T est également pensée pour atteindre facilement toutes les zones du visage et du cou.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q8 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>🔋</span></div>\n          <span class=\"skfaq-q-text\">Comment recharger l'appareil et quelle est son autonomie ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Le Skinyliss se recharge via le <strong>câble USB-C fourni</strong> en environ <strong>1h30</strong>. Une charge complète offre jusqu'à <strong>15 séances</strong> d'utilisation de 10 minutes. Un voyant LED intégré vous indique le niveau de batterie en temps réel — vous ne serez jamais prise au dépourvu.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q9 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>↩️</span></div>\n          <span class=\"skfaq-q-text\">Quelle est votre garantie et politique de remboursement ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Nous offrons une <strong>garantie satisfaite ou remboursée de 90 jours</strong>. Si vous n'êtes pas satisfaite des résultats après une utilisation régulière, contactez notre service client et nous vous remboursons intégralement — <strong>sans question posée</strong>. Nous sommes convaincues de l'efficacité de notre produit et nous assumons ce risque entièrement.\n        </div>\n      </div>\n    </div>\n\n    <!-- Q10 -->\n    <div class=\"skfaq-item\">\n      <button class=\"skfaq-question\" aria-expanded=\"false\">\n        <div class=\"skfaq-q-left\">\n          <div class=\"skfaq-q-icon\"><span>🚚</span></div>\n          <span class=\"skfaq-q-text\">Quels sont les délais et les frais de livraison ?</span>\n        </div>\n        <div class=\"skfaq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"skfaq-answer\">\n        <div class=\"skfaq-answer-inner\">\n          Les commandes sont expédiées sous <strong>24 à 48h ouvrées</strong>. La livraison standard est <strong>gratuite</strong> et prend 3 à 5 jours ouvrés. Vous recevrez un email de confirmation avec votre <strong>numéro de suivi</strong> dès l'expédition de votre colis.\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n\n</section>\n\n<script>\n(function () {\n  var items = document.querySelectorAll('.skfaq-item');\n  items.forEach(function (item) {\n    var btn = item.querySelector('.skfaq-question');\n    btn.addEventListener('click', function () {\n      var isOpen = item.classList.contains('open');\n      items.forEach(function (i) {\n        i.classList.remove('open');\n        i.querySelector('.skfaq-question').setAttribute('aria-expanded', 'false');\n      });\n      if (!isOpen) {\n        item.classList.add('open');\n        btn.setAttribute('aria-expanded', 'true');\n      }\n    });\n  });\n})();\n</script>",
