        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .ann-bar {\n    --pink:  #E8547A;\n    --dark:  #1C1C2E;\n    --gold:  #e8c97e;\n    --white: #ffffff;\n    background: var(--dark);\n    overflow: hidden;\n    white-space: nowrap;\n    padding: 11px 0;\n    font-family: 'Inter', -apple-system, sans-serif;\n    width: 100%;\n    position: relative;\n    z-index: 100;\n  }\n\n  /* ── TRACK DÉFILANT ── */\n  .ann-track {\n    display: inline-flex;\n    align-items: center;\n    animation: ann-scroll 35s linear infinite;\n  }\n\n  .ann-track:hover {\n    animation-play-state: paused;\n  }\n\n  /* ── ITEM ── */\n  .ann-item {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 0 32px;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--white);\n    white-space: nowrap;\n  }\n\n  /* Point séparateur doré */\n  .ann-dot {\n    width: 5px;\n    height: 5px;\n    background: var(--gold);\n    border-radius: 50%;\n    flex-shrink: 0;\n    display: inline-block;\n  }\n\n  /* Icône optionnelle avant le texte */\n  .ann-icon {\n    font-size: 13px;\n    line-height: 1;\n    flex-shrink: 0;\n  }\n\n  /* Texte en rose pour mettre en valeur */\n  .ann-item .highlight {\n    color: var(--gold);\n  }\n\n  @keyframes ann-scroll {\n    from { transform: translateX(0); }\n    to   { transform: translateX(-50%); }\n  }\n</style>\n\n<div class=\"ann-bar\" role=\"marquee\" aria-label=\"Annonces\">\n  <div class=\"ann-track\">\n\n    {%- comment -%}\n      ══════════════════════════════════════════\n      PERSONNALISATION\n      Modifiez les textes ci-dessous librement.\n      Dupliquez un bloc <span class=\"ann-item\">\n      pour ajouter un message.\n      Les blocs sont dupliqués (x2) pour la\n      boucle infinie.\n      ══════════════════════════════════════════\n    {%- endcomment -%}\n\n    {%- for i in (1..2) -%}\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">↩️</span>\n        Satisfaite ou remboursée — <span class=\"highlight\">&nbsp;90 jours</span>\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">⭐</span>\n        <span class=\"highlight\">+1 500 clientes</span>&nbsp; satisfaites · Note 4.8/5\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🔒</span>\n        Paiement <span class=\"highlight\">&nbsp;100% sécurisé</span> &nbsp;· Données protégées\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🚚</span>\n        Livraison <span class=\"highlight\">&nbsp;rapide & sécurisée</span> &nbsp;· Suivi inclus\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">⏳</span>\n        Stock limité — <span class=\"highlight\">&nbsp;Plus que 5 unités</span> &nbsp;disponibles !\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🔥</span>\n        Offre expire dans <span class=\"highlight\">&nbsp;24h</span> &nbsp;— Ne ratez pas cette opportunité !\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">🎁</span>\n        Sérum contour des yeux <span class=\"highlight\">&nbsp;offert</span> &nbsp;avec chaque commande\n        <span class=\"ann-dot\"></span>\n      </span>\n\n      <span class=\"ann-item\">\n        <span class=\"ann-icon\">📖</span>\n        Guide beauté anti-âge <span class=\"highlight\">&nbsp;offert</span> &nbsp;à chaque achat\n        <span class=\"ann-dot\"></span>\n      </span>\n\n    {%- endfor -%}\n\n  </div>\n</div>",
