nt-size: 13px; padding: 0 12px; }\n  }\n</style>\n\n<div class=\"skinyliss-result\">\n\n  <div class=\"result-badge\">TRANFORMATION VISIBLE</div>\n\n  <h2 class=\"result-title\">\n    Résultat <span>Avant / Après</span>\n  </h2>\n\n  <p class=\"result-subtitle\">\n    Découvrez l'efficacité de notre technologie anti-rides avancée\n  </p>\n\n  <div class=\"result-divider\">\n    <div class=\"result-line\"></div>\n    <div class=\"result-diamond\"></div>\n    <div class=\"result-line\"></div>\n  </div>\n\n</div>",
