    "custom_liquid_UdqcTj": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .faq-ticker-wrap {\n    background: #1C1C2E;\n    overflow: hidden;\n    white-space: nowrap;\n    padding: 10px 0;\n    font-family: 'Inter', sans-serif;\n  }\n  .faq-ticker-track {\n    display: inline-flex;\n    animation: faq-ticker 32s linear infinite;\n  }\n  .faq-ticker-track:hover { animation-play-state: paused; }\n  .faq-ticker-item {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 0 30px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.13em;\n    text-transform: uppercase;\n    color: #fff;\n  }\n  .faq-ticker-dot {\n    width: 5px; height: 5px;\n    background: #E8547A;\n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n  @keyframes faq-ticker {\n    from { transform: translateX(0); }\n    to   { transform: translateX(-50%); }\n  }\n\n  .faq-section {\n    --pink:       #E8547A;\n    --pink-light: #fce8ef;\n    --pink-mid:   #f4a8bc;\n    --dark:       #1C1C2E;\n    --white:      #ffffff;\n    --grey:       #f7f4f8;\n    --text-soft:  rgba(28,28,46,0.5);\n    --border:     rgba(232,84,122,0.15);\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    background: var(--grey);\n    padding: 64px 24px 80px;\n  }\n\n  .faq-header { text-align: center; margin-bottom: 52px; }\n  .faq-tag { display: inline-block; font-size: 10.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pink); border: 1.5px solid var(--pink); border-radius: 100px; padding: 5px 16px; margin-bottom: 16px; }\n  .faq-header h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.9rem, 4vw, 3rem); font-weight: 700; color: var(--dark); line-height: 1.2; margin: 0 0 12px; }\n  .faq-header h2 em { font-style: italic; color: var(--pink); }\n  .faq-header p { font-size: 14px; color: var(--text-soft); max-width: 480px; margin: 0 auto; line-height: 1.7; }\n\n  .faq-layout { max-width: 780px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }\n\n  .faq-item { background: var(--white); border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(28,28,46,0.05); border: 1.5px solid transparent; transition: border-color 0.3s, box-shadow 0.3s; }\n  .faq-item.open { border-color: var(--border); box-shadow: 0 8px 32px rgba(232,84,122,0.1); }\n\n  .faq-question { width: 100%; background: none; border: none; padding: 20px 22px; display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; text-align: left; }\n  .faq-question:hover .faq-q-text { color: var(--pink); }\n  .faq-q-left { display: flex; align-items: center; gap: 14px; }\n  .faq-q-icon { width: 32px; height: 32px; background: var(--pink-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 14px; transition: background 0.3s; }\n  .faq-item.open .faq-q-icon { background: var(--pink); }\n  .faq-item.open .faq-q-icon span { filter: brightness(10); }\n  .faq-q-text { font-size: 14px; font-weight: 600; color: var(--dark); line-height: 1.4; transition: color 0.2s; }\n  .faq-item.open .faq-q-text { color: var(--pink); }\n\n  .faq-chevron { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.35s ease, background 0.3s, border-color 0.3s; background: var(--white); }\n  .faq-item.open .faq-chevron { transform: rotate(180deg); background: var(--pink); border-color: var(--pink); }\n  .faq-chevron svg { width: 12px; height: 12px; stroke: var(--dark); stroke-width: 2.5; fill: none; stroke-linecap: round; stroke-linejoin: round; transition: stroke 0.3s; }\n  .faq-item.open .faq-chevron svg { stroke: #fff; }\n\n  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1); }\n  .faq-item.open .faq-answer { max-height: 400px; }\n  .faq-answer-inner { padding: 16px 22px 22px 68px; font-size: 13.5px; color: var(--text-soft); line-height: 1.75; border-top: 1px solid var(--border); }\n  .faq-answer-inner strong { color: var(--dark); font-weight: 600; }\n</style>\n\n<!-- TICKER -->\n<div class=\"faq-ticker-wrap\" aria-hidden=\"true\">\n  <div class=\"faq-ticker-track\">\n    {% assign faq_phrases = \"Rides Effacées en 14 Jours,Peau Lissée & Repulpée,Résultats Visibles dès la 1ère Semaine,Anti-Rides Cliniquement Prouvé,Rajeunissez de 10 Ans,Satisfait ou Remboursé,Sans Injection ni Chirurgie\" | split: \",\" %}\n    {% for i in (1..2) %}\n      {% for phrase in faq_phrases %}\n        <span class=\"faq-ticker-item\">\n          <span class=\"faq-ticker-dot\"></span>{{ phrase }}\n        </span>\n      {% endfor %}\n    {% endfor %}\n  </div>\n</div>\n\n<section class=\"faq-section\">\n\n  <div class=\"faq-header\">\n    <div class=\"faq-tag\">Questions fréquentes</div>\n    <h2>Vous avez des <em>questions ?</em></h2>\n    <p>Tout ce que vous devez savoir sur EyeLiss et son fonctionnement.</p>\n  </div>\n\n  <div class=\"faq-layout\" id=\"faqList\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>⏱</span></div><span class=\"faq-q-text\">Au bout de combien de temps vais-je voir des résultats ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">La plupart de nos clientes constatent une <strong>réduction visible des poches et cernes dès 2 semaines</strong> d'utilisation régulière. Pour les rides et ridules, les résultats optimaux apparaissent généralement entre <strong>4 et 6 semaines</strong>. Chaque peau est différente, mais 91% de nos utilisatrices observent une amélioration visible en moins de 5 semaines.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>💆‍♀️</span></div><span class=\"faq-q-text\">Le masque est-il douloureux à utiliser ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">Non, EyeLiss est <strong>totalement indolore</strong>. La technologie LED + EMS génère de légères vibrations et une douce chaleur que la plupart des utilisatrices trouvent relaxantes. Vous pouvez ajuster l'intensité selon votre confort grâce aux <strong>3 niveaux disponibles</strong>.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>🔁</span></div><span class=\"faq-q-text\">À quelle fréquence dois-je utiliser le masque ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">Nous recommandons une utilisation <strong>quotidienne de 10 minutes</strong> pour des résultats optimaux. Une fois les résultats atteints, une séance <strong>3 à 4 fois par semaine</strong> suffit pour maintenir l'effet.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>🧴</span></div><span class=\"faq-q-text\">Dois-je utiliser un sérum ou une crème avec le masque ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">Oui, nous recommandons d'appliquer une <strong>noisette de sérum ou crème contour des yeux</strong> avant chaque séance. Cela améliore la conductivité et amplifie l'effet micro-courant. Le <strong>Sérum Contour des Yeux offert</strong> avec votre commande est spécialement formulé pour fonctionner en synergie avec EyeLiss.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>🌿</span></div><span class=\"faq-q-text\">Le masque est-il adapté à tous les types de peau ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">Oui, EyeLiss convient à <strong>tous les types de peau</strong> — sèche, mixte, grasse ou sensible. La technologie LED est non-invasive et sans UV. Si vous avez une condition cutanée particulière, consultez votre dermatologue avant utilisation.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>↩️</span></div><span class=\"faq-q-text\">Quelle est votre politique de remboursement ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">Nous offrons une <strong>garantie satisfait ou remboursé de 90 jours</strong>. Si vous n'êtes pas satisfaite des résultats, contactez notre service client et nous vous remboursons intégralement — sans question posée.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>🚚</span></div><span class=\"faq-q-text\">Quels sont les délais de livraison ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">Les commandes sont expédiées sous <strong>24 à 48h ouvrées</strong>. La livraison standard prend <strong>3 à 5 jours ouvrés</strong>. Vous recevrez un email de confirmation avec votre numéro de suivi dès l'expédition.</div></div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" aria-expanded=\"false\">\n        <div class=\"faq-q-left\"><div class=\"faq-q-icon\"><span>🔋</span></div><span class=\"faq-q-text\">Comment recharger l'appareil ?</span></div>\n        <div class=\"faq-chevron\"><svg viewBox=\"0 0 14 14\"><polyline points=\"2,4 7,10 12,4\"/></svg></div>\n      </button>\n      <div class=\"faq-answer\"><div class=\"faq-answer-inner\">EyeLiss se recharge via le <strong>câble USB-C fourni</strong>. Une charge complète prend environ <strong>1h30</strong> et offre jusqu'à <strong>15 séances</strong> d'utilisation. Un voyant LED indique le niveau de charge en temps réel.</div></div>\n    </div>\n\n  </div>\n\n</section>\n\n<script>\n(function () {\n  var items = document.querySelectorAll('.faq-item');\n  items.forEach(function (item) {\n    var btn = item.querySelector('.faq-question');\n    btn.addEventListener('click', function () {\n      var isOpen = item.classList.contains('open');\n      items.forEach(function (i) {\n        i.classList.remove('open');\n        i.querySelector('.faq-question').setAttribute('aria-expanded', 'false');\n      });\n      if (!isOpen) {\n        item.classList.add('open');\n        btn.setAttribute('aria-expanded', 'true');\n      }\n    });\n  });\n})();\n</script>",
