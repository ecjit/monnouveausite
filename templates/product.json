r h2 {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: clamp(1.8rem, 4vw, 3rem);\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.15;\n    margin: 0 0 10px;\n  }\n  .eyeliss-header h2 em {\n    font-style: italic;\n    color: var(--pink);\n  }\n  .eyeliss-header p {\n    font-size: 13px;\n    color: var(--text-soft);\n    letter-spacing: 0.04em;\n    margin: 0 0 18px;\n  }\n  .eyeliss-rating-strip { display: flex; justify-content: center; }\n  .eyeliss-rating-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    background: var(--dark);\n    color: #fff;\n    border-radius: 100px;\n    padding: 8px 20px;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.04em;\n  }\n  .eyeliss-rating-pill .stars { color: #f5c518; letter-spacing: 2px; font-size: 13px; }\n  .eyeliss-rating-pill .sep  { opacity: 0.35; }\n\n  /* ─── CAROUSEL ─── */\n  .eyeliss-carousel-outer {\n    background: var(--grey);\n    padding: 24px 0 40px;\n    margin-top: 0;\n  }\n\n  .eyeliss-carousel-track {\n    display: flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    scroll-behavior: smooth;\n    padding: 8px 20px 16px;\n    /* Cache la scrollbar */\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n  }\n\n  .eyeliss-carousel-track::-webkit-scrollbar {\n    display: none;\n  }\n\n  /* ─── CARD ─── */\n  .eyeliss-card {\n    flex: 0 0 248px;\n    scroll-snap-align: start;\n    border-radius: 20px;\n    overflow: hidden;\n    cursor: pointer;\n    background: var(--white);\n    box-shadow: 0 4px 24px rgba(28,28,46,0.08), 0 1px 6px rgba(28,28,46,0.04);\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n    position: relative;\n  }\n\n  @media (max-width: 600px) {\n    .eyeliss-carousel-track {\n      padding: 8px 0 16px;\n    }\n    .eyeliss-card {\n      flex: 0 0 85vw;\n      scroll-snap-align: center;\n    }\n  }\n\n  .eyeliss-card:hover {\n    transform: translateY(-6px);\n    box-shadow: 0 16px 48px rgba(232,84,122,0.18), 0 4px 16px rgba(28,28,46,0.08);\n  }\n  .eyeliss-card-media {\n    position: relative;\n    width: 100%;\n    padding-bottom: 170%;\n    overflow: hidden;\n    background: #1C1C2E;\n  }\n\n  /* Vidéo réelle */\n  .eyeliss-card-media video {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  /* Overlay gradient sur la vidéo */\n  .eyeliss-card-media::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to top, rgba(28,28,46,0.80) 0%, rgba(28,28,46,0.1) 45%, transparent 100%);\n    pointer-events: none;\n    z-index: 1;\n  }\n\n  /* ─── BADGE ACHAT VÉRIFIÉ ─── */\n  .eyeliss-card-badge {\n    position: absolute;\n    top: 12px;\n    left: 12px;\n    z-index: 3;\n    background: rgba(255,255,255,0.92);\n    backdrop-filter: blur(8px);\n    -webkit-backdrop-filter: blur(8px);\n    color: var(--dark);\n    font-size: 9.5px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 5px 10px 5px 7px;\n    border-radius: 100px;\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.12);\n  }\n  .eyeliss-badge-check {\n    width: 16px; height: 16px;\n    background: #2ecc71;\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n  .eyeliss-badge-check svg {\n    width: 9px; height: 9px;\n    stroke: #fff; stroke-width: 2.5;\n    fill: none; stroke-linecap: round; stroke-linejoin: round;\n  }\n\n  /* ─── INFO BAS ─── */\n  .eyeliss-card-info {\n    position: absolute;\n    bottom: 48px;\n    left: 14px; right: 14px;\n    z-index: 2;\n  }\n  .eyeliss-card-info .username {\n    font-size: 10.5px; font-weight: 600;\n    letter-spacing: 0.1em;\n    color: rgba(255,255,255,0.75);\n    text-transform: uppercase;\n  }\n  .eyeliss-card-info .caption {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-style: italic; font-size: 13px;\n    color: #fff; margin-top: 4px; line-height: 1.4;\n  }\n\n  /* ─── BOUTON PLAY ─── */\n  .eyeliss-play-btn {\n    position: absolute;\n    bottom: 12px; right: 12px;\n    z-index: 3;\n    width: 42px; height: 42px;\n    background: var(--pink);\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    box-shadow: 0 4px 16px rgba(232,84,122,0.5);\n    transition: transform 0.2s, background 0.2s;\n    border: none; cursor: pointer;\n  }\n  .eyeliss-play-btn:hover { background: var(--dark); transform: scale(1.12); }\n  .eyeliss-play-btn svg { width: 14px; height: 14px; fill: #fff; margin-left: 2px; }\n\n  /* Icône pause (affichée quand vidéo joue) */\n  .eyeliss-play-btn .icon-pause { display: none; }\n  .eyeliss-play-btn.playing .icon-play  { display: none; }\n  .eyeliss-play-btn.playing .icon-pause { display: block; }\n  .eyeliss-play-btn.playing { background: var(--dark); }\n\n  /* ─── NAVIGATION ─── */\n  .eyeliss-carousel-nav {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 18px;\n    padding: 20px 20px 32px;\n    background: var(--grey);\n  }\n  .eyeliss-nav-btn {\n    width: 42px; height: 42px;\n    border-radius: 50%;\n    border: 2px solid var(--border);\n    background: var(--white);\n    color: var(--pink); font-size: 17px;\n    cursor: pointer;\n    display: flex; align-items: center; justify-content: center;\n    transition: all 0.2s;\n    box-shadow: 0 2px 8px rgba(28,28,46,0.07);\n  }\n  .eyeliss-nav-btn:hover {\n    background: var(--pink); color: var(--white);\n    border-color: var(--pink); transform: scale(1.08);\n  }\n  .eyeliss-dots { display: flex; gap: 7px; align-items: center; }\n  .eyeliss-dot {\n    width: 8px; height: 8px;\n    border-radius: 100px;\n    background: var(--pink-mid);\n    cursor: pointer; transition: all 0.3s; opacity: 0.4;\n    border: none; padding: 0;\n  }\n  .eyeliss-dot.active { background: var(--pink); width: 20px; opacity: 1; }\n\n  /* ─── MODALE VIDÉO (plein écran) ─── */\n  .eyeliss-modal-overlay {\n    display: none;\n    position: fixed; inset: 0;\n    background: rgba(28,28,46,0.92);\n    z-index: 9999;\n    align-items: center; justify-content: center;\n    backdrop-filter: blur(8px);\n    -webkit-backdrop-filter: blur(8px);\n  }\n  .eyeliss-modal-overlay.open { display: flex; }\n  .eyeliss-modal-inner {\n    position: relative;\n    width: min(90vw, 380px);\n    border-radius: 24px;\n    overflow: hidden;\n    background: #000;\n    box-shadow: 0 32px 80px rgba(0,0,0,0.6);\n  }\n  .eyeliss-modal-inner video {\n    width: 100%;\n    max-height: 82vh;\n    display: block;\n    object-fit: cover;\n  }\n  .eyeliss-modal-close {\n    position: absolute; top: 14px; right: 14px;\n    width: 36px; height: 36px;\n    background: rgba(255,255,255,0.9);\n    border: none; border-radius: 50%;\n    font-size: 18px; cursor: pointer;\n    display: flex; align-items: center; justify-content: center;\n    z-index: 10; color: var(--dark);\n    transition: background 0.2s, transform 0.2s;\n  }\n  .eyeliss-modal-close:hover { background: #fff; transform: scale(1.08); }\n</style>\n\n<div class=\"eyeliss-section\">\n\n  <!-- TICKER -->\n  <div class=\"eyeliss-ticker-wrap\" aria-hidden=\"true\">\n    <div class=\"eyeliss-ticker-track\">\n      {% assign phrases = \"Rides Effacées en 14 Jours,Peau Lissée & Repulpée,Résultats Visibles dès la 1ère Semaine,Anti-Rides Cliniquement Prouvé,Rajeunissez de 10 Ans,Satisfait ou Remboursé,Sans Injection, Sans Chirurgie\" | split: \",\" %}\n      {% for i in (1..2) %}\n        {% for phrase in phrases %}\n          <span class=\"eyeliss-ticker-item\">\n            <span class=\"eyeliss-ticker-dot\"></span>{{ phrase }}\n          </span>\n        {% endfor %}\n      {% endfor %}\n    </div>\n  </div>\n\n  <!-- HEADER -->\n  <div class=\"eyeliss-header\">\n    <div class=\"eyeliss-tag\">Témoignages clients</div>\n    <h2>Voyez les rides <em>disparaître</em></h2>\n    <p>Des résultats réels, partagés par notre communauté</p>\n    <div class=\"eyeliss-rating-strip\">\n      <div class=\"eyeliss-rating-pill\">\n        <span class=\"stars\">★★★★★</span>\n        <span class=\"sep\">|</span>\n        4.8/5\n        <span class=\"sep\">—</span>\n        +1&nbsp;500 avis vérifiés\n      </div>\n    </div>\n  </div>\n\n  <!-- CAROUSEL -->\n  <div class=\"eyeliss-carousel-outer\">\n    <div class=\"eyeliss-carousel-track\" id=\"eyelissTrack\">\n\n      <!-- CARD 1 -->\n      <div class=\"eyeliss-card\">\n        <div class=\"eyeliss-card-media\">\n          <video\n            src=\"https://cdn.shopify.com/videos/c/vp/4cbb132c25924335b07a3222e97565c7/4cbb132c25924335b07a3222e97565c7.HD-1080p-7.2Mbps-70873927.mp4\"\n            playsinline loop muted preload=\"metadata\">\n          </video>\n          <div class=\"eyeliss-card-badge\">\n            <span class=\"eyeliss-badge-check\">\n              <svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg>\n            </span>\n            Achat Vérifié\n          </div>\n          <div class=\"eyeliss-card-info\">\n            <div class=\"username\">@mariebeauty</div>\n            <div class=\"caption\">\"Mes rides ont complètement disparu en 2 semaines !\"</div>\n          </div>\n          <button class=\"eyeliss-play-btn\" aria-label=\"Lire la vidéo\">\n            <svg class=\"icon-play\" viewBox=\"0 0 24 24\"><polygon points=\"5,3 19,12 5,21\"/></svg>\n            <svg class=\"icon-pause\" viewBox=\"0 0 24 24\" fill=\"#fff\" width=\"14\" height=\"14\"><rect x=\"4\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/><rect x=\"16\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/></svg>\n          </button>\n        </div>\n      </div>\n\n      <!-- CARD 2 -->\n      <div class=\"eyeliss-card\">\n        <div class=\"eyeliss-card-media\">\n          <video\n            src=\"https://cdn.shopify.com/videos/c/vp/527e37cea2f0416c9d8c93f6ff7dff6e/527e37cea2f0416c9d8c93f6ff7dff6e.HD-1080p-4.8Mbps-70875201.mp4\"\n            playsinline loop muted preload=\"metadata\">\n          </video>\n          <div class=\"eyeliss-card-badge\">\n            <span class=\"eyeliss-badge-check\">\n              <svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg>\n            </span>\n            Achat Vérifié\n          </div>\n          <div class=\"eyeliss-card-info\">\n            <div class=\"username\">@sophiedaily</div>\n            <div class=\"caption\">\"Je n'avais pas vu ma peau aussi lisse depuis 15 ans !\"</div>\n          </div>\n          <button class=\"eyeliss-play-btn\" aria-label=\"Lire la vidéo\">\n            <svg class=\"icon-play\" viewBox=\"0 0 24 24\"><polygon points=\"5,3 19,12 5,21\"/></svg>\n            <svg class=\"icon-pause\" viewBox=\"0 0 24 24\" fill=\"#fff\" width=\"14\" height=\"14\"><rect x=\"4\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/><rect x=\"16\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/></svg>\n          </button>\n        </div>\n      </div>\n\n      <!-- CARD 3 -->\n      <div class=\"eyeliss-card\">\n        <div class=\"eyeliss-card-media\">\n          <video\n            src=\"https://cdn.shopify.com/videos/c/vp/e843d4308b174bf29239cac190206b0f/e843d4308b174bf29239cac190206b0f.HD-1080p-4.8Mbps-70875199.mp4\"\n            playsinline loop muted preload=\"metadata\">\n          </video>\n          <div class=\"eyeliss-card-badge\">\n            <span class=\"eyeliss-badge-check\">\n              <svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg>\n            </span>\n            Achat Vérifié\n          </div>\n          <div class=\"eyeliss-card-info\">\n            <div class=\"username\">@chloelifestyle</div>\n            <div class=\"caption\">\"Les rides autour de mes yeux ont fondu, c'est bluffant !\"</div>\n          </div>\n          <button class=\"eyeliss-play-btn\" aria-label=\"Lire la vidéo\">\n            <svg class=\"icon-play\" viewBox=\"0 0 24 24\"><polygon points=\"5,3 19,12 5,21\"/></svg>\n            <svg class=\"icon-pause\" viewBox=\"0 0 24 24\" fill=\"#fff\" width=\"14\" height=\"14\"><rect x=\"4\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/><rect x=\"16\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/></svg>\n          </button>\n        </div>\n      </div>\n\n      <!-- CARD 4 -->\n      <div class=\"eyeliss-card\">\n        <div class=\"eyeliss-card-media\">\n          <video\n            src=\"https://cdn.shopify.com/videos/c/vp/48cd563d70c745edab45ddeaf3436dd1/48cd563d70c745edab45ddeaf3436dd1.HD-1080p-4.8Mbps-70875203.mp4\"\n            playsinline loop muted preload=\"metadata\">\n          </video>\n          <div class=\"eyeliss-card-badge\">\n            <span class=\"eyeliss-badge-check\">\n              <svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg>\n            </span>\n            Achat Vérifié\n          </div>\n          <div class=\"eyeliss-card-info\">\n            <div class=\"username\">@laurencefit</div>\n            <div class=\"caption\">\"Mon visage est repulpé, les rides se sont effacées !\"</div>\n          </div>\n          <button class=\"eyeliss-play-btn\" aria-label=\"Lire la vidéo\">\n            <svg class=\"icon-play\" viewBox=\"0 0 24 24\"><polygon points=\"5,3 19,12 5,21\"/></svg>\n            <svg class=\"icon-pause\" viewBox=\"0 0 24 24\" fill=\"#fff\" width=\"14\" height=\"14\"><rect x=\"4\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/><rect x=\"16\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/></svg>\n          </button>\n        </div>\n      </div>\n\n      <!-- CARD 5 -->\n      <div class=\"eyeliss-card\">\n        <div class=\"eyeliss-card-media\">\n          <video\n            src=\"https://cdn.shopify.com/videos/c/vp/135dd03d82b2485e9d2ed91e953ed18d/135dd03d82b2485e9d2ed91e953ed18d.HD-1080p-3.3Mbps-70875205.mp4\"\n            playsinline loop muted preload=\"metadata\">\n          </video>\n          <div class=\"eyeliss-card-badge\">\n            <span class=\"eyeliss-badge-check\">\n              <svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg>\n            </span>\n            Achat Vérifié\n          </div>\n          <div class=\"eyeliss-card-info\">\n            <div class=\"username\">@isabellev</div>\n            <div class=\"caption\">\"Incroyable ! Plus aucune ride visible, je me sens rajeunie !\"</div>\n          </div>\n          <button class=\"eyeliss-play-btn\" aria-label=\"Lire la vidéo\">\n            <svg class=\"icon-play\" viewBox=\"0 0 24 24\"><polygon points=\"5,3 19,12 5,21\"/></svg>\n            <svg class=\"icon-pause\" viewBox=\"0 0 24 24\" fill=\"#fff\" width=\"14\" height=\"14\"><rect x=\"4\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/><rect x=\"16\" y=\"3\" width=\"4\" height=\"18\" rx=\"1\"/></svg>\n          </button>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- NAVIGATION -->\n  <div class=\"eyeliss-carousel-nav\">\n    <button class=\"eyeliss-nav-btn\" id=\"eyelissPrev\" aria-label=\"Précédent\">&#8592;</button>\n    <div class=\"eyeliss-dots\" id=\"eyelissDots\" role=\"tablist\"></div>\n    <button class=\"eyeliss-nav-btn\" id=\"eyelissNext\" aria-label=\"Suivant\">&#8594;</button>\n  </div>\n\n</div>\n\n<!-- MODALE PLEIN ÉCRAN -->\n<div class=\"eyeliss-modal-overlay\" id=\"eyelissModal\" role=\"dialog\" aria-modal=\"true\">\n  <div class=\"eyeliss-modal-inner\">\n    <button class=\"eyeliss-modal-close\" id=\"eyelissModalClose\" aria-label=\"Fermer\">✕</button>\n    <video id=\"eyelissModalVideo\" controls playsinline muted style=\"max-height:82vh;\"></video>\n  </div>\n</div>\n\n<script>\n(function () {\n  var track      = document.getElementById('eyelissTrack');\n  var cards      = Array.from(track.querySelectorAll('.eyeliss-card'));\n  var dotsWrap   = document.getElementById('eyelissDots');\n  var prevBtn    = document.getElementById('eyelissPrev');\n  var nextBtn    = document.getElementById('eyelissNext');\n  var modal      = document.getElementById('eyelissModal');\n  var modalVid   = document.getElementById('eyelissModalVideo');\n  var modalClose = document.getElementById('eyelissModalClose');\n\n  var current   = 0;\n  var total     = cards.length;\n  var autoTimer = null;\n\n  /* ── Dots ── */\n  cards.forEach(function (_, i) {\n    var d = document.createElement('button');\n    d.className = 'eyeliss-dot' + (i === 0 ? ' active' : '');\n    d.setAttribute('aria-label', 'Slide ' + (i + 1));\n    d.addEventListener('click', function () { stopAuto(); goTo(i); startAuto(); });\n    dotsWrap.appendChild(d);\n  });\n\n  function updateDots(i) {\n    dotsWrap.querySelectorAll('.eyeliss-dot').forEach(function (d, idx) {\n      d.classList.toggle('active', idx === i);\n    });\n    current = i;\n  }\n\n  /* ── Scroll vers card i ── */\n  function goTo(i) {\n    i = (i + total) % total;\n    var card = cards[i];\n    track.scrollTo({ left: card.offsetLeft - 20, behavior: 'smooth' });\n    updateDots(i);\n  }\n\n  /* ── Auto-play ── */\n  function startAuto() {\n    autoTimer = setInterval(function () { goTo(current + 1); }, 4000);\n  }\n  function stopAuto() { clearInterval(autoTimer); }\n\n  prevBtn.addEventListener('click', function () { stopAuto(); goTo(current - 1); startAuto(); });\n  nextBtn.addEventListener('click', function () { stopAuto(); goTo(current + 1); startAuto(); });\n\n  /* ── Sync dots au scroll natif ── */\n  var scrollTimer;\n  track.addEventListener('scroll', function () {\n    clearTimeout(scrollTimer);\n    scrollTimer = setTimeout(function () {\n      var closest = 0, minDist = Infinity;\n      cards.forEach(function (card, i) {\n        var dist = Math.abs(card.offsetLeft - track.scrollLeft - 20);\n        if (dist < minDist) { minDist = dist; closest = i; }\n      });\n      updateDots(closest);\n    }, 80);\n  });\n\n  /* ── Ouverture modale sur clic ── */\n  function openModal(card) {\n    var vid = card.querySelector('video');\n    if (!vid) return;\n    modalVid.src = vid.src;\n    modalVid.load();\n    modalVid.play().catch(function () {});\n    modal.classList.add('open');\n    stopAuto();\n  }\n\n  cards.forEach(function (card) {\n    card.addEventListener('click', function (e) {\n      e.stopPropagation();\n      openModal(card);\n    });\n  });\n\n  function closeModal() {\n    modal.classList.remove('open');\n    modalVid.pause();\n    modalVid.src = '';\n    startAuto();\n  }\n\n  modalClose.addEventListener('click', closeModal);\n  modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });\n  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });\n\n  /* ── Init ── */\n  goTo(0);\n  startAuto();\n})();\n</script>",
