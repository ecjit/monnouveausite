    "custom_liquid_aWbhRH": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .ba-section {\n    --pink:       #E8547A;\n    --pink-light: #fce8ef;\n    --pink-mid:   #f4a8bc;\n    --dark:       #1C1C2E;\n    --white:      #ffffff;\n    --grey:       #f7f4f8;\n    --text:       #1C1C2E;\n    --text-soft:  rgba(28,28,46,0.5);\n    --border:     rgba(232,84,122,0.15);\n    --green:      #2ecc71;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    background: var(--grey);\n    padding: 64px 20px 72px;\n    overflow-x: hidden;\n  }\n\n  /* ─── TICKER ─── */\n  .ba-ticker-wrap {\n    background: #1C1C2E;\n    overflow: hidden;\n    white-space: nowrap;\n    padding: 10px 0;\n  }\n  .ba-ticker-track {\n    display: inline-flex;\n    animation: ba-ticker 32s linear infinite;\n  }\n  .ba-ticker-track:hover { animation-play-state: paused; }\n  .ba-ticker-item {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 0 30px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.13em;\n    text-transform: uppercase;\n    color: #ffffff;\n    font-family: 'Inter', sans-serif;\n  }\n  .ba-ticker-dot {\n    width: 5px; height: 5px;\n    background: #E8547A;\n    border-radius: 50%;\n    flex-shrink: 0;\n    display: inline-block;\n  }\n  @keyframes ba-ticker {\n    from { transform: translateX(0); }\n    to   { transform: translateX(-50%); }\n  }\n\n  /* ─── SECTION ─── */\n  .ba-header {\n    text-align: center;\n    margin-bottom: 48px;\n  }\n\n  .ba-tag {\n    display: inline-block;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--pink);\n    border: 1.5px solid var(--pink);\n    border-radius: 100px;\n    padding: 5px 16px;\n    margin-bottom: 16px;\n  }\n\n  .ba-header h2 {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: clamp(1.9rem, 4vw, 3rem);\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.15;\n    margin: 0 0 12px;\n  }\n\n  .ba-header h2 em {\n    font-style: italic;\n    color: var(--pink);\n  }\n\n  .ba-header p {\n    font-size: 14px;\n    color: var(--text-soft);\n    max-width: 480px;\n    margin: 0 auto;\n    line-height: 1.7;\n  }\n\n  /* ─── GRILLE ─── */\n  .ba-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 24px;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  @media (max-width: 900px) {\n    .ba-grid { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  @media (max-width: 580px) {\n    .ba-grid { grid-template-columns: 1fr; }\n  }\n\n  /* ─── CARD ─── */\n  .ba-card {\n    background: var(--white);\n    border-radius: 22px;\n    overflow: hidden;\n    box-shadow: 0 4px 24px rgba(28,28,46,0.07), 0 1px 6px rgba(28,28,46,0.04);\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .ba-card:hover {\n    transform: translateY(-6px);\n    box-shadow: 0 20px 56px rgba(232,84,122,0.16), 0 4px 16px rgba(28,28,46,0.07);\n  }\n\n  /* ─── IMAGE AVANT / APRÈS ─── */\n  .ba-images {\n    position: relative;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 3px;\n    background: var(--dark);\n    aspect-ratio: 4/3;\n    overflow: hidden;\n  }\n\n  .ba-images img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center top;\n    display: block;\n  }\n\n  /* Labels AVANT / APRÈS */\n  .ba-label {\n    position: absolute;\n    bottom: 10px;\n    font-size: 9px;\n    font-weight: 800;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #fff;\n    background: rgba(28,28,46,0.65);\n    backdrop-filter: blur(4px);\n    padding: 3px 10px;\n    border-radius: 100px;\n  }\n\n  .ba-label.avant { left: calc(25% - 24px); }\n  .ba-label.apres { left: calc(75% - 24px); }\n\n  /* Séparateur central */\n  .ba-divider {\n    position: absolute;\n    top: 0; bottom: 0;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 3px;\n    background: var(--white);\n    z-index: 2;\n  }\n\n  .ba-divider-icon {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 28px; height: 28px;\n    background: var(--white);\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.2);\n    z-index: 3;\n    font-size: 12px;\n    color: var(--pink);\n    font-weight: 800;\n  }\n\n  /* ─── CORPS CARD ─── */\n  .ba-body {\n    padding: 20px 20px 24px;\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n    flex: 1;\n  }\n\n  /* Nom + badge */\n  .ba-identity {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex-wrap: wrap;\n  }\n\n  .ba-name {\n    font-size: 15px;\n    font-weight: 700;\n    color: var(--dark);\n  }\n\n  .ba-verified {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    background: rgba(46,204,113,0.1);\n    border: 1px solid rgba(46,204,113,0.3);\n    color: #1a9e52;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    padding: 3px 10px 3px 6px;\n    border-radius: 100px;\n  }\n\n  .ba-verified-dot {\n    width: 14px; height: 14px;\n    background: var(--green);\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .ba-verified-dot svg {\n    width: 8px; height: 8px;\n    stroke: #fff; stroke-width: 2.5;\n    fill: none; stroke-linecap: round; stroke-linejoin: round;\n  }\n\n  /* Bullets résultats */\n  .ba-results {\n    list-style: none;\n    padding: 0; margin: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 7px;\n  }\n\n  .ba-results li {\n    display: flex;\n    align-items: flex-start;\n    gap: 8px;\n    font-size: 12.5px;\n    font-weight: 500;\n    color: var(--dark);\n    line-height: 1.45;\n  }\n\n  .ba-results li::before {\n    content: '';\n    width: 18px; height: 18px;\n    min-width: 18px;\n    border-radius: 50%;\n    background: var(--pink);\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 12 12' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='2,6 5,9 10,3' stroke='white' stroke-width='2.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E\");\n    background-repeat: no-repeat;\n    background-position: center;\n    background-size: 9px;\n    margin-top: 1px;\n    flex-shrink: 0;\n  }\n\n  /* Citation */\n  .ba-quote {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-style: italic;\n    font-size: 13px;\n    color: var(--text-soft);\n    line-height: 1.65;\n    border-left: 3px solid var(--pink-mid);\n    padding-left: 12px;\n    margin-top: 4px;\n  }\n\n  /* ─── FOOTER STATS ─── */\n  .ba-footer {\n    text-align: center;\n    margin-top: 52px;\n  }\n\n  .ba-stats {\n    display: inline-flex;\n    align-items: center;\n    gap: 0;\n    background: var(--white);\n    border-radius: 20px;\n    overflow: hidden;\n    box-shadow: 0 4px 20px rgba(28,28,46,0.08);\n    flex-wrap: wrap;\n  }\n\n  .ba-stat {\n    padding: 20px 36px;\n    text-align: center;\n    border-right: 1px solid var(--border);\n  }\n\n  .ba-stat:last-child { border-right: none; }\n\n  .ba-stat-num {\n    font-family: 'Playfair Display', serif;\n    font-size: 1.9rem;\n    font-weight: 700;\n    color: var(--pink);\n    display: block;\n    line-height: 1;\n  }\n\n  .ba-stat-label {\n    font-size: 11px;\n    font-weight: 600;\n    color: var(--text-soft);\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    margin-top: 4px;\n    display: block;\n  }\n\n  @media (max-width: 580px) {\n    .ba-stat { padding: 16px 24px; }\n    .ba-stat-num { font-size: 1.5rem; }\n  }\n</style>\n\n<!-- TICKER -->\n<div class=\"ba-ticker-wrap\" aria-hidden=\"true\">\n  <div class=\"ba-ticker-track\">\n    {% assign ba_phrases = \"Rides Effacées en 14 Jours,Peau Lissée & Repulpée,Résultats Visibles dès la 1ère Semaine,Anti-Rides Cliniquement Prouvé,Rajeunissez de 10 Ans,Satisfait ou Remboursé,Sans Injection, Sans Chirurgie\" | split: \",\" %}\n    {% for i in (1..2) %}\n      {% for phrase in ba_phrases %}\n        <span class=\"ba-ticker-item\">\n          <span class=\"ba-ticker-dot\"></span>{{ phrase }}\n        </span>\n      {% endfor %}\n    {% endfor %}\n  </div>\n</div>\n\n<section class=\"ba-section\">\n\n  <!-- EN-TÊTE -->\n  <div class=\"ba-header\">\n    <div class=\"ba-tag\">Avant / Après</div>\n    <h2>Des résultats <em>réels & visibles</em></h2>\n    <p>Découvrez les transformations authentiques de nos clientes après seulement quelques semaines d'utilisation.</p>\n  </div>\n\n  <!-- GRILLE DES CARDS -->\n  <div class=\"ba-grid\">\n\n    <!-- ── CARD 1 ── -->\n    <div class=\"ba-card\">\n      <div class=\"ba-images\">\n        <!--\n          ⚠️ CARD 1 : les 2 noms de fichiers fournis sont identiques.\n          Remplace le src de l'image \"après\" par le bon fichier.\n        -->\n        <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/hf_20260401_144343_9dd24b93-612b-4d35-bdb4-355fb33ad4b0.png\" alt=\"Avant traitement\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/hf_20260401_144357_1f8c4c53-73aa-4634-a7fa-2b8acba8372c.png\" alt=\"Après traitement\">\n        <div class=\"ba-divider\">\n          <div class=\"ba-divider-icon\">↔</div>\n        </div>\n        <span class=\"ba-label avant\">Avant</span>\n        <span class=\"ba-label apres\">Après</span>\n      </div>\n      <div class=\"ba-body\">\n        <div class=\"ba-identity\">\n          <span class=\"ba-name\">Yasmine T.</span>\n          <span class=\"ba-verified\">\n            <span class=\"ba-verified-dot\"><svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg></span>\n            Achat Vérifié\n          </span>\n        </div>\n        <ul class=\"ba-results\">\n          <li>Affaissement et cernes visiblement réduits</li>\n          <li>Fermeté et éclat de la peau améliorés</li>\n          <li>Teint plus sain et reposé</li>\n        </ul>\n        <p class=\"ba-quote\">\"J'ai remarqué des résultats visibles en seulement 2 semaines. Mon contour des yeux est plus lumineux et plus jeune.\"</p>\n      </div>\n    </div>\n\n    <!-- ── CARD 2 ── -->\n    <div class=\"ba-card\">\n      <div class=\"ba-images\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/hf_20260401_144730_f49d962d-46ed-4195-b232-e2cf256ec4a4.png\" alt=\"Avant traitement\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/hf_20260401_144533_41dc9594-901b-4c65-b6ca-fc5e94ae8782.png\" alt=\"Après traitement\">\n        <div class=\"ba-divider\">\n          <div class=\"ba-divider-icon\">↔</div>\n        </div>\n        <span class=\"ba-label avant\">Avant</span>\n        <span class=\"ba-label apres\">Après</span>\n      </div>\n      <div class=\"ba-body\">\n        <div class=\"ba-identity\">\n          <span class=\"ba-name\">Emma R.</span>\n          <span class=\"ba-verified\">\n            <span class=\"ba-verified-dot\"><svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg></span>\n            Achat Vérifié\n          </span>\n        </div>\n        <ul class=\"ba-results\">\n          <li>Texture de peau visiblement plus lisse</li>\n          <li>Pattes d'oie et rides réduites</li>\n          <li>Teint plus lumineux et unifié</li>\n        </ul>\n        <p class=\"ba-quote\">\"Après 4 semaines, mes amies me demandaient ce que j'avais changé. La différence est vraiment remarquable.\"</p>\n      </div>\n    </div>\n\n    <!-- ── CARD 3 ── -->\n    <div class=\"ba-card\">\n      <div class=\"ba-images\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/hf_20260401_144159_6bf2e037-d858-47d6-b675-4d4fd735b96a.png\" alt=\"Avant traitement\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0976/2888/1238/files/hf_20260401_144507_41bf290f-cb26-4dd2-94af-29f8bafd77bc.png\" alt=\"Après traitement\">\n        <div class=\"ba-divider\">\n          <div class=\"ba-divider-icon\">↔</div>\n        </div>\n        <span class=\"ba-label avant\">Avant</span>\n        <span class=\"ba-label apres\">Après</span>\n      </div>\n      <div class=\"ba-body\">\n        <div class=\"ba-identity\">\n          <span class=\"ba-name\">Isabelle M.</span>\n          <span class=\"ba-verified\">\n            <span class=\"ba-verified-dot\"><svg viewBox=\"0 0 12 12\"><polyline points=\"2,6 5,9 10,3\"/></svg></span>\n            Achat Vérifié\n          </span>\n        </div>\n        <ul class=\"ba-results\">\n          <li>Zone sous les yeux visiblement adoucie</li>\n          <li>Signes de fatigue réduits</li>\n          <li>Apparence globale plus jeune</li>\n        </ul>\n        <p class=\"ba-quote\">\"Je me sens plus reposée et fraîche chaque jour. Ce produit a dépassé toutes mes attentes.\"</p>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- STATS -->\n  <div class=\"ba-footer\">\n    <div class=\"ba-stats\">\n      <div class=\"ba-stat\">\n        <span class=\"ba-stat-num\">94%</span>\n        <span class=\"ba-stat-label\">Rides réduites</span>\n      </div>\n      <div class=\"ba-stat\">\n        <span class=\"ba-stat-num\">14j</span>\n        <span class=\"ba-stat-label\">Premiers résultats</span>\n      </div>\n      <div class=\"ba-stat\">\n        <span class=\"ba-stat-num\">+1500</span>\n        <span class=\"ba-stat-label\">Clientes satisfaites</span>\n      </div>\n    </div>\n  </div>\n\n</section>",
