    "custom_liquid_UTDrcR": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  /* ─── TICKER ─── */\n  .rt-ticker-wrap {\n    background: #1C1C2E;\n    overflow: hidden;\n    white-space: nowrap;\n    padding: 10px 0;\n    font-family: 'Inter', sans-serif;\n  }\n  .rt-ticker-track {\n    display: inline-flex;\n    animation: rt-ticker 32s linear infinite;\n  }\n  .rt-ticker-track:hover { animation-play-state: paused; }\n  .rt-ticker-item {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 0 30px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.13em;\n    text-transform: uppercase;\n    color: #fff;\n  }\n  .rt-ticker-dot {\n    width: 5px; height: 5px;\n    background: #E8547A;\n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n  @keyframes rt-ticker {\n    from { transform: translateX(0); }\n    to   { transform: translateX(-50%); }\n  }\n\n  /* ─── SECTION ─── */\n  .rt-section {\n    --pink:       #E8547A;\n    --pink-light: #fce8ef;\n    --pink-mid:   #f4a8bc;\n    --dark:       #1C1C2E;\n    --white:      #ffffff;\n    --grey:       #f7f4f8;\n    --text-soft:  rgba(28,28,46,0.5);\n    --border:     rgba(232,84,122,0.15);\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    background: var(--grey);\n    padding: 64px 24px 72px;\n    overflow: hidden;\n  }\n\n  /* ─── HEADER ─── */\n  .rt-header {\n    text-align: center;\n    margin-bottom: 52px;\n  }\n  .rt-tag {\n    display: inline-block;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--pink);\n    border: 1.5px solid var(--pink);\n    border-radius: 100px;\n    padding: 5px 16px;\n    margin-bottom: 16px;\n  }\n  .rt-header h2 {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: clamp(1.8rem, 3.5vw, 2.8rem);\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.2;\n    margin: 0 0 12px;\n  }\n  .rt-header h2 em {\n    font-style: italic;\n    color: var(--pink);\n  }\n  .rt-header p {\n    font-size: 14px;\n    color: var(--text-soft);\n    max-width: 520px;\n    margin: 0 auto;\n    line-height: 1.7;\n  }\n\n  /* ─── GRILLE 4 ÉTAPES ─── */\n  .rt-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 20px;\n    max-width: 1200px;\n    margin: 0 auto 40px;\n  }\n\n  @media (max-width: 900px) {\n    .rt-grid { grid-template-columns: repeat(2, 1fr); }\n  }\n  @media (max-width: 520px) {\n    .rt-grid { grid-template-columns: 1fr; }\n  }\n\n  /* ─── CARD ─── */\n  .rt-card {\n    background: var(--white);\n    border-radius: 20px;\n    overflow: hidden;\n    box-shadow: 0 4px 24px rgba(28,28,46,0.07), 0 1px 6px rgba(28,28,46,0.04);\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n    display: flex;\n    flex-direction: column;\n  }\n  .rt-card:hover {\n    transform: translateY(-6px);\n    box-shadow: 0 20px 56px rgba(232,84,122,0.16), 0 4px 16px rgba(28,28,46,0.07);\n  }\n\n  /* ─── VIDÉO ─── */\n  .rt-video-wrap {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 9/13;\n    overflow: hidden;\n    background: var(--dark);\n  }\n  .rt-video-wrap video {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n  /* Numéro d'étape flottant */\n  .rt-step-num {\n    position: absolute;\n    top: 14px;\n    left: 14px;\n    z-index: 3;\n    width: 36px; height: 36px;\n    background: var(--pink);\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 1rem;\n    font-weight: 700;\n    color: #fff;\n    box-shadow: 0 4px 14px rgba(232,84,122,0.45);\n  }\n  /* Overlay bas */\n  .rt-video-wrap::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to top, rgba(28,28,46,0.5) 0%, transparent 50%);\n    pointer-events: none;\n  }\n\n  /* ─── CORPS CARD ─── */\n  .rt-body {\n    padding: 18px 18px 22px;\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n  .rt-step-label {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: var(--pink);\n  }\n  .rt-step-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 1.1rem;\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.25;\n    margin: 0;\n  }\n  .rt-step-desc {\n    font-size: 12.5px;\n    color: var(--text-soft);\n    line-height: 1.7;\n    margin: 4px 0 0;\n  }\n\n  /* ─── NOTE BAS ─── */\n  .rt-note {\n    text-align: center;\n    font-size: 13px;\n    color: var(--text-soft);\n    font-style: italic;\n    max-width: 600px;\n    margin: 0 auto;\n    padding: 20px 0 0;\n    border-top: 1.5px solid var(--border);\n  }\n  .rt-note span { color: var(--pink); font-style: normal; font-weight: 600; }\n</style>\n\n<!-- TICKER -->\n<div class=\"rt-ticker-wrap\" aria-hidden=\"true\">\n  <div class=\"rt-ticker-track\">\n    {% assign rt_phrases = \"Routine de 10 Minutes,Sans Injection ni Chirurgie,Rides Effacées en 14 Jours,Peau Lissée & Repulpée,Anti-Rides Cliniquement Prouvé,Satisfait ou Remboursé,Rajeunissez de 10 Ans\" | split: \",\" %}\n    {% for i in (1..2) %}\n      {% for phrase in rt_phrases %}\n        <span class=\"rt-ticker-item\">\n          <span class=\"rt-ticker-dot\"></span>{{ phrase }}\n        </span>\n      {% endfor %}\n    {% endfor %}\n  </div>\n</div>\n\n<!-- SECTION -->\n<section class=\"rt-section\">\n\n  <!-- HEADER -->\n  <div class=\"rt-header\">\n    <div class=\"rt-tag\">Protocole d'utilisation</div>\n    <h2>Routine <em>sans effort en 10 minutes</em></h2>\n    <p>Sans chirurgie, sans injection, sans temps d'arrêt — juste 10 minutes par jour pour des résultats visibles.</p>\n  </div>\n\n  <!-- GRILLE -->\n  <div class=\"rt-grid\">\n\n    <!-- ÉTAPE 1 -->\n    <div class=\"rt-card\">\n      <div class=\"rt-video-wrap\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/714eed8482bd4aaa92b3a0dafa120b52.mp4\"\n          autoplay muted loop playsinline></video>\n        <div class=\"rt-step-num\">1</div>\n      </div>\n      <div class=\"rt-body\">\n        <div class=\"rt-step-label\">Étape 1</div>\n        <h3 class=\"rt-step-title\">Nettoyage du visage</h3>\n        <p class=\"rt-step-desc\">Commencez sur une peau propre — lavez votre visage pour éliminer le sébum et les impuretés afin que le traitement agisse efficacement.</p>\n      </div>\n    </div>\n\n    <!-- ÉTAPE 2 -->\n    <div class=\"rt-card\">\n      <div class=\"rt-video-wrap\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/7209124c1ab1412d95bbd8e3bf3cead1.mp4\"\n          autoplay muted loop playsinline></video>\n        <div class=\"rt-step-num\">2</div>\n      </div>\n      <div class=\"rt-body\">\n        <div class=\"rt-step-label\">Étape 2</div>\n        <h3 class=\"rt-step-title\">Application du sérum</h3>\n        <p class=\"rt-step-desc\">Appliquez une noisette de crème ou sérum contour des yeux sous vos yeux pour amplifier l'effet micro-courant.</p>\n      </div>\n    </div>\n\n    <!-- ÉTAPE 3 -->\n    <div class=\"rt-card\">\n      <div class=\"rt-video-wrap\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/35ffd4a62ccb44b496f329a61947bcbf.mp4\"\n          autoplay muted loop playsinline></video>\n        <div class=\"rt-step-num\">3</div>\n      </div>\n      <div class=\"rt-body\">\n        <div class=\"rt-step-label\">Étape 3</div>\n        <h3 class=\"rt-step-title\">Activation du masque</h3>\n        <p class=\"rt-step-desc\">Allumez votre appareil et sélectionnez le mode d'impulsion micro-courant et le niveau d'intensité souhaité.</p>\n      </div>\n    </div>\n\n    <!-- ÉTAPE 4 -->\n    <div class=\"rt-card\">\n      <div class=\"rt-video-wrap\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/20435b002d0a47e4866dac5b92f9e9d0.mp4\"\n          autoplay muted loop playsinline></video>\n        <div class=\"rt-step-num\">4</div>\n      </div>\n      <div class=\"rt-body\">\n        <div class=\"rt-step-label\">Étape 4</div>\n        <h3 class=\"rt-step-title\">Détente & résultats</h3>\n        <p class=\"rt-step-desc\">Installez-vous confortablement et laissez l'appareil agir pendant que vous vous relaxez — c'est lui qui fait tout le travail !</p>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- NOTE -->\n  <p class=\"rt-note\">\n    <span>✨</span> Détendez-vous et laissez l'appareil opérer sa magie lors d'une session quotidienne de <span>5 à 10 minutes</span> !\n  </p>\n\n</section>",
