clamp(1.9rem, 4vw, 3rem);\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.2;\n    margin: 0;\n  }\n\n  .tr-title h2 em {\n    font-style: italic;\n    color: var(--pink);\n  }\n\n  /* ─── LAYOUT 2 COLONNES ─── */\n  .tr-layout {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 56px;\n    align-items: center;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  @media (max-width: 800px) {\n    .tr-layout {\n      grid-template-columns: 1fr;\n      gap: 40px;\n    }\n  }\n\n  /* ─── COLONNE STATS ─── */\n  .tr-stats {\n    display: flex;\n    flex-direction: column;\n    gap: 32px;\n  }\n\n  .tr-stat-item {\n    display: flex;\n    align-items: center;\n    gap: 24px;\n  }\n\n  /* Cercle de pourcentage */\n  .tr-circle {\n    position: relative;\n    width: 88px;\n    height: 88px;\n    flex-shrink: 0;\n  }\n\n  .tr-circle svg {\n    width: 88px;\n    height: 88px;\n    transform: rotate(-90deg);\n  }\n\n  .tr-circle-bg {\n    fill: none;\n    stroke: var(--border);\n    stroke-width: 6;\n  }\n\n  .tr-circle-fill {\n    fill: none;\n    stroke: var(--pink);\n    stroke-width: 6;\n    stroke-linecap: round;\n    transition: stroke-dashoffset 1.2s ease;\n  }\n\n  .tr-circle-num {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 1.3rem;\n    font-weight: 700;\n    color: var(--dark);\n  }\n\n  .tr-stat-text {\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--dark);\n    line-height: 1.6;\n  }\n\n  .tr-stat-text strong {\n    display: block;\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--pink);\n    letter-spacing: 0.04em;\n    margin-bottom: 3px;\n    text-transform: uppercase;\n    font-size: 10px;\n  }\n\n  /* Note bas de page */\n  .tr-note {\n    font-size: 11px;\n    font-style: italic;\n    color: var(--text-soft);\n    margin-top: 8px;\n    padding-top: 20px;\n    border-top: 1px solid var(--border);\n  }\n\n  /* ─── COLONNE IMAGES ─── */\n  .tr-images {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    border-radius: 22px;\n    overflow: hidden;\n    box-shadow: 0 16px 56px rgba(232,84,122,0.14), 0 4px 18px rgba(28,28,46,0.08);\n  }\n\n  .tr-img-wrap {\n    position: relative;\n    overflow: hidden;\n    min-height: 220px;\n    background: #eee;\n  }\n\n  .tr-img-wrap img {\n    width: 100%;\n    aspect-ratio: 16/7;\n    object-fit: cover;\n    object-position: center;\n    display: block;\n  }\n\n  .tr-img-label {\n    position: absolute;\n    top: 14px;\n    left: 14px;\n    font-family: 'Playfair Display', serif;\n    font-size: 1.2rem;\n    font-weight: 700;\n    color: #fff;\n    text-shadow: 0 2px 8px rgba(0,0,0,0.4);\n  }\n\n  .tr-img-label.apres {\n    color: #fff;\n  }\n\n  /* Placeholder si pas d'image */\n  .tr-img-placeholder {\n    width: 100%;\n    aspect-ratio: 16/7;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .tr-img-placeholder.avant-bg {\n    background: linear-gradient(135deg, #ddd 0%, #bbb 100%);\n    color: rgba(0,0,0,0.4);\n  }\n\n  .tr-img-placeholder.apres-bg {\n    background: linear-gradient(135deg, #f4a8bc 0%, #E8547A 100%);\n    color: rgba(255,255,255,0.8);\n  }\n</style>\n\n<!-- TICKER -->\n<div class=\"tr-ticker-wrap\" aria-hidden=\"true\">\n  <div class=\"tr-ticker-track\">\n    {% assign tr_phrases = \"Rides Effacées en 14 Jours,Peau Lissée & Repulpée,Résultats Visibles dès la 1ère Semaine,Anti-Rides Cliniquement Prouvé,Rajeunissez de 10 Ans,Satisfait ou Remboursé,Sans Injection, Sans Chirurgie\" | split: \",\" %}\n    {% for i in (1..2) %}\n      {% for phrase in tr_phrases %}\n        <span class=\"tr-ticker-item\">\n          <span class=\"tr-ticker-dot\"></span>{{ phrase }}\n        </span>\n      {% endfor %}\n    {% endfor %}\n  </div>\n</div>\n\n<!-- SECTION -->\n<section class=\"tr-section\">\n\n  <!-- TITRE -->\n  <div class=\"tr-title\">\n    <div class=\"tr-tag\">Étude clinique</div>\n    <h2>Une transformation <em>visible en quelques semaines</em></h2>\n  </div>\n\n  <!-- LAYOUT -->\n  <div class=\"tr-layout\">\n\n    <!-- ── STATS ── -->\n    <div class=\"tr-stats\">\n\n      <!-- Stat 1 : 82% -->\n      <div class=\"tr-stat-item\">\n        <div class=\"tr-circle\">\n          <svg viewBox=\"0 0 88 88\">\n            <circle class=\"tr-circle-bg\" cx=\"44\" cy=\"44\" r=\"38\"/>\n            <circle class=\"tr-circle-fill\" cx=\"44\" cy=\"44\" r=\"38\"\n              stroke-dasharray=\"238.76\"\n              stroke-dashoffset=\"42.98\"/>\n          </svg>\n          <div class=\"tr-circle-num\">82%</div>\n        </div>\n        <div class=\"tr-stat-text\">\n          <strong>En seulement 2 semaines</strong>\n          Réduction visible des cernes & de la pigmentation dès 2 semaines d'utilisation\n        </div>\n      </div>\n\n      <!-- Stat 2 : 87% -->\n      <div class=\"tr-stat-item\">\n        <div class=\"tr-circle\">\n          <svg viewBox=\"0 0 88 88\">\n            <circle class=\"tr-circle-bg\" cx=\"44\" cy=\"44\" r=\"38\"/>\n            <circle class=\"tr-circle-fill\" cx=\"44\" cy=\"44\" r=\"38\"\n              stroke-dasharray=\"238.76\"\n              stroke-dashoffset=\"31.04\"/>\n          </svg>\n          <div class=\"tr-circle-num\">87%</div>\n        </div>\n        <div class=\"tr-stat-text\">\n          <strong>En seulement 2 semaines</strong>\n          Réduction significative des poches sous les yeux après 2 semaines\n        </div>\n      </div>\n\n      <!-- Stat 3 : 91% -->\n      <div class=\"tr-stat-item\">\n        <div class=\"tr-circle\">\n          <svg viewBox=\"0 0 88 88\">\n            <circle class=\"tr-circle-bg\" cx=\"44\" cy=\"44\" r=\"38\"/>\n            <circle class=\"tr-circle-fill\" cx=\"44\" cy=\"44\" r=\"38\"\n              stroke-dasharray=\"238.76\"\n              stroke-dashoffset=\"21.49\"/>\n          </svg>\n          <div class=\"tr-circle-num\">91%</div>\n        </div>\n        <div class=\"tr-stat-text\">\n          <strong>En seulement 5 semaines</strong>\n          Amélioration visible des ridules & rides en seulement 5 semaines\n        </div>\n      </div>\n\n      <p class=\"tr-note\">* Résultats issus d'études consommateurs réalisées sur des utilisatrices régulières du produit.</p>\n    </div>\n\n    <!-- ── IMAGES AVANT / APRÈS ── -->\n    <div class=\"tr-images\">\n\n      <!-- VIDÉO UNIQUE -->\n      <div class=\"tr-img-wrap\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/9c70a13576484f72a091ab0bf1e4d7e6.mp4\"\n          autoplay muted loop playsinline\n          style=\"width:100%;height:100%;min-height:480px;object-fit:cover;display:block;\">\n        </video>\n      </div>\n\n    </div>\n\n  </div>\n</section>\n\n<script>\n/* Animation des cercles au scroll */\n(function () {\n  var items = document.querySelectorAll('.tr-circle-fill');\n  var animated = false;\n\n  function animate() {\n    if (animated) return;\n    var section = document.querySelector('.tr-section');\n    if (!section) return;\n    var rect = section.getBoundingClientRect();\n    if (rect.top < window.innerHeight * 0.85) {\n      animated = true;\n      /* Les valeurs stroke-dashoffset sont déjà définies en CSS — elles s'animent via transition */\n      items.forEach(function (el) {\n        var final = el.getAttribute('stroke-dashoffset');\n        el.style.strokeDashoffset = '238.76';\n        requestAnimationFrame(function () {\n          requestAnimationFrame(function () {\n            el.style.strokeDashoffset = final;\n          });\n        });\n      });\n    }\n  }\n\n  window.addEventListener('scroll', animate, { passive: true });\n  animate();\n})();\n</script>",
