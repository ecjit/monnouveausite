{% comment %}
  Section : Comparateur Avant/Après SKINYLISS
  Design : Thème Skinyliss — Inter + Playfair Display
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  .skinyliss-comparison * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* ─── SECTION ─── */
  .skinyliss-comparison {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: #f7f4f8;
    padding: 64px 24px 72px;
  }

  .skinyliss-comparison .container {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (max-width: 768px) {
    .skinyliss-comparison .container {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  /* ─── COLONNE TEXTE ─── */
  .skinyliss-comparison .text-col {}

  .skinyliss-comparison .sc-tag {
    display: inline-block;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #E8547A;
    border: 1.5px solid #E8547A;
    border-radius: 100px;
    padding: 5px 16px;
    margin-bottom: 18px;
  }

  .skinyliss-comparison h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    font-weight: 700;
    color: #1C1C2E;
    line-height: 1.2;
    margin-bottom: 6px;
    text-align: left;
  }

  .skinyliss-comparison h1 em {
    font-style: italic;
    color: #E8547A;
    font-weight: 400;
  }

  .sc-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 18px 0 24px;
    max-width: 200px;
  }
  .sc-line {
    flex: 1;
    height: 1.5px;
    background: rgba(232,84,122,0.25);
    border-radius: 2px;
  }
  .sc-diamond {
    width: 6px; height: 6px;
    background: #E8547A;
    transform: rotate(45deg);
    flex-shrink: 0;
    border-radius: 1px;
  }

  .skinyliss-comparison .text-content p {
    font-size: 14px;
    line-height: 1.75;
    color: rgba(28,28,46,0.6);
    font-weight: 400;
    margin-bottom: 12px;
  }

  .skinyliss-comparison .text-content p:last-child {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 13.5px;
    color: rgba(28,28,46,0.45);
    margin-bottom: 0;
  }

  /* ─── COLONNE SLIDER ─── */
  .skinyliss-comparison .comparison-container {
    position: relative;
    width: 100%;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 16px 56px rgba(232,84,122,0.14), 0 4px 18px rgba(28,28,46,0.08);
  }

  .skinyliss-comparison .comparison-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
  }

  .skinyliss-comparison .comparison-image {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .skinyliss-comparison .image-before { z-index: 1; }
  .skinyliss-comparison .image-after {
    z-index: 2;
    clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);
  }

  .skinyliss-comparison .slider-container {
    position: absolute;
    top: 0; left: 50%;
    height: 100%;
    width: 3px;
    background: #ffffff;
    cursor: ew-resize;
    z-index: 3;
    transform: translateX(-50%);
  }

  .skinyliss-comparison .slider-button {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 44px; height: 44px;
    background: #E8547A;
    border-radius: 50%;
    box-shadow: 0 4px 16px rgba(232,84,122,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, background 0.2s;
  }

  .skinyliss-comparison .slider-button:hover {
    background: #1C1C2E;
    transform: translate(-50%, -50%) scale(1.1);
  }

  .skinyliss-comparison .slider-button::before,
  .skinyliss-comparison .slider-button::after {
    content: '';
    position: absolute;
    width: 0; height: 0;
    border-style: solid;
  }

  .skinyliss-comparison .slider-button::before {
    left: 10px;
    border-width: 6px 8px 6px 0;
    border-color: transparent #fff transparent transparent;
  }

  .skinyliss-comparison .slider-button::after {
    right: 10px;
    border-width: 6px 0 6px 8px;
    border-color: transparent transparent transparent #fff;
  }

  .skinyliss-comparison .label {
    position: absolute;
    top: 16px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #1C1C2E;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 100px;
    z-index: 4;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .skinyliss-comparison .label-before { left: 16px; }
  .skinyliss-comparison .label-after  { right: 16px; }

  /* ─── BARRE DÉFILANTE ─── */
  .ann-bar {
    --pink:  #E8547A;
    --dark:  #1C1C2E;
    --gold:  #e8c97e;
    --white: #ffffff;
    background: var(--dark);
    overflow: hidden;
    white-space: nowrap;
    padding: 11px 0;
    font-family: 'Inter', -apple-system, sans-serif;
    width: 100%;
    position: relative;
    z-index: 100;
  }
  .ann-track {
    display: inline-flex;
    align-items: center;
    animation: ann-scroll 35s linear infinite;
  }
  .ann-track:hover { animation-play-state: paused; }
  .ann-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0 32px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
    white-space: nowrap;
  }
  .ann-dot {
    width: 5px; height: 5px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }
  .ann-icon { font-size: 13px; line-height: 1; flex-shrink: 0; }
  .ann-item .highlight { color: var(--gold); }
  @keyframes ann-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

<!-- BARRE DÉFILANTE -->
<div class="ann-bar" role="marquee" aria-label="Annonces">
  <div class="ann-track">
    {%- for i in (1..2) -%}
      <span class="ann-item">
        <span class="ann-icon">↩️</span>
        Satisfaite ou remboursée — <span class="highlight">&nbsp;30 jours</span>
        <span class="ann-dot"></span>
      </span>
      <span class="ann-item">
        <span class="ann-icon">⭐</span>
        <span class="highlight">+1 300 clientes</span>&nbsp; satisfaites · Note 4.0/5
        <span class="ann-dot"></span>
      </span>
      <span class="ann-item">
        <span class="ann-icon">🔒</span>
        Paiement <span class="highlight">&nbsp;100% sécurisé</span> &nbsp;· Données protégées
        <span class="ann-dot"></span>
      </span>
      <span class="ann-item">
        <span class="ann-icon">🚚</span>
        Livraison <span class="highlight">&nbsp;rapide & sécurisée</span> &nbsp;· Suivi inclus
        <span class="ann-dot"></span>
      </span>
      <span class="ann-item">
        <span class="ann-icon">🔥</span>
        Offre expire dans <span class="highlight">&nbsp;24h</span> &nbsp;— Ne ratez pas cette opportunité !
        <span class="ann-dot"></span>
      </span>
    {%- endfor -%}
  </div>
</div>

<div class="skinyliss-comparison">
  <div class="container">

    <!-- TEXTE -->
    <div class="text-col">
      <div class="sc-tag">Transformation réelle</div>
      <h1>{{ section.settings.title }}</h1>
      <div class="sc-divider">
        <div class="sc-line"></div>
        <div class="sc-diamond"></div>
        <div class="sc-line"></div>
      </div>
      <div class="text-content">
        <p>{{ section.settings.text1 }}</p>
        <p>{{ section.settings.text2 }}</p>
      </div>
    </div>

    <!-- SLIDER -->
    <div class="comparison-container">
      <div class="comparison-wrapper">
        <img src="{{ section.settings.image_before | img_url: 'master' }}"
             alt="Avant traitement SKINYLISS"
             class="comparison-image image-before"
             id="imageBefore-{{ section.id }}">

        <img src="{{ section.settings.image_after | img_url: 'master' }}"
             alt="Après traitement SKINYLISS"
             class="comparison-image image-after"
             id="imageAfter-{{ section.id }}">

        <div class="label label-before">{{ section.settings.label_before }}</div>
        <div class="label label-after">{{ section.settings.label_after }}</div>

        <div class="slider-container" id="slider-{{ section.id }}">
          <div class="slider-button"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function() {
  var slider    = document.getElementById('slider-{{ section.id }}');
  var imgAfter  = document.getElementById('imageAfter-{{ section.id }}');
  var container = slider.closest('.comparison-wrapper');
  var isDragging = false;

  function updateSlider(x) {
    var rect = container.getBoundingClientRect();
    var pct  = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
    slider.style.left = pct + '%';
    imgAfter.style.clipPath = 'polygon(0 0, ' + pct + '% 0, ' + pct + '% 100%, 0 100%)';
  }

  slider.addEventListener('mousedown',  function()  { isDragging = true; });
  document.addEventListener('mousemove',function(e) { if (isDragging) updateSlider(e.clientX); });
  document.addEventListener('mouseup',  function()  { isDragging = false; });

  slider.addEventListener('touchstart', function(e) { isDragging = true; e.preventDefault(); }, { passive: false });
  document.addEventListener('touchmove', function(e) { if (isDragging) updateSlider(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchend',  function()  { isDragging = false; });

  container.addEventListener('click', function(e) { updateSlider(e.clientX); });
})();
</script>

{% schema %}
{
  "name": "Avant/Après SKINYLISS",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Résultats visibles en 30 jours"
    },
    {
      "type": "textarea",
      "id": "text1",
      "label": "Texte 1",
      "default": "Découvrez la transformation spectaculaire obtenue grâce à notre appareil LED 7 couleurs SKINYLISS. En seulement 30 jours d'utilisation régulière, observez la réduction visible des imperfections et l'amélioration du teint."
    },
    {
      "type": "textarea",
      "id": "text2",
      "label": "Texte 2",
      "default": "Faites glisser le curseur pour comparer les résultats avant et après le traitement."
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Image Avant"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "Image Après"
    },
    {
      "type": "text",
      "id": "label_before",
      "label": "Label Avant",
      "default": "Avant"
    },
    {
      "type": "text",
      "id": "label_after",
      "label": "Label Après",
      "default": "Après"
    }
  ],
  "presets": [
    {
      "name": "Avant/Après SKINYLISS"
    }
  ]
}
{% endschema %}
